---
import Layout from '../layouts/Layout.astro';
interface Props {
	title: string;
	english: string;
	description: string;
	accent: string;
	soft: string;
	items: { number: string; name: string; note: string }[];
}
const { title, english, description, accent, soft, items } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${title} | 코이노니아 마켓`} description={description}>
	<main class="category" style={`--accent: ${accent}; --soft: ${soft};`}>
		<header class="category__header">
			<a class="home-link" href={`${base}/`} aria-label="코이노니아 마켓 메인으로"><span aria-hidden="true">←</span> 코이노니아 마켓</a>
			<nav aria-label="마켓 카테고리"><a href={`${base}/food`}>먹거리</a><a href={`${base}/goods`}>팔거리</a><a href={`${base}/play`}>놀거리</a></nav>
		</header>
		<section class="category__hero">
			<p class="category__eyebrow">{english}</p>
			<h1>{title}</h1>
			<p class="category__description">{description}</p>
			<div class="category__line" aria-hidden="true"></div>
		</section>
		<section class="category__items" aria-label={`${title} 목록`}>
			{items.map((item) => (
				<article class="item">
					<span class="item__number">{item.number}</span>
					<div><h2>{item.name}</h2><p>{item.note}</p></div>
					<span class="item__arrow" aria-hidden="true">↗</span>
				</article>
			))}
		</section>
		<footer><p>KOINONIA MARKET</p><a href={base}>처음으로 돌아가기</a></footer>
	</main>
</Layout>

<style>
	.category { --accent: #a74834; --soft: #ead4c9; min-height: 100svh; padding: clamp(18px, 3.5vw, 54px); overflow: hidden; background: radial-gradient(circle at 90% 12%, var(--soft), transparent 30%), #f7f1e5; }
	.category__header { display: flex; justify-content: space-between; align-items: center; gap: 24px; padding-bottom: 20px; border-bottom: 1px solid rgb(47 41 30 / 20%); animation: reveal 600ms ease both; }
	.home-link, .category__header nav a, footer a { color: inherit; text-decoration: none; }
	.home-link { display: flex; gap: 10px; align-items: center; font-weight: 800; letter-spacing: -.04em; }
	.category__header nav { display: flex; gap: clamp(12px, 2.5vw, 34px); font-size: 14px; font-weight: 700; }
	.category__header nav a { padding: 6px 0; border-bottom: 2px solid transparent; }
	.category__header nav a:hover { color: var(--accent); border-color: var(--accent); }
	.category__hero { position: relative; max-width: 1120px; margin: 0 auto; padding: clamp(70px, 12vw, 170px) 0 clamp(60px, 9vw, 120px); }
	.category__eyebrow { margin: 0 0 16px; color: var(--accent); font-size: 12px; font-weight: 900; letter-spacing: .2em; animation: rise 650ms 100ms ease both; }
	.category h1 { margin: 0; color: var(--accent); font-family: 'Gowun Dodum', sans-serif; font-size: clamp(76px, 16vw, 210px); font-weight: 400; line-height: .85; letter-spacing: -.12em; animation: rise 800ms 160ms cubic-bezier(.16, 1, .3, 1) both; }
	.category__description { max-width: 460px; margin: clamp(32px, 5vw, 60px) 0 0 auto; font-size: clamp(16px, 1.6vw, 21px); line-height: 1.75; letter-spacing: -.04em; animation: rise 700ms 250ms ease both; }
	.category__line { position: absolute; right: -15vw; bottom: 20%; left: 0; z-index: -1; height: 1px; background: var(--accent); opacity: .28; transform: rotate(-5deg); }
	.category__items { display: grid; max-width: 1120px; margin: 0 auto; border-top: 2px solid var(--accent); }
	.item { display: grid; grid-template-columns: 58px 1fr auto; gap: clamp(12px, 2vw, 28px); align-items: center; padding: clamp(24px, 4vw, 48px) 4px; border-bottom: 1px solid rgb(47 41 30 / 22%); animation: rise 700ms calc(300ms + var(--delay, 0ms)) ease both; transition: padding 200ms ease, background 200ms ease; }
	.item:nth-child(2) { --delay: 80ms; }
	.item:nth-child(3) { --delay: 160ms; }
	.item:hover { padding-right: 18px; padding-left: 18px; background: color-mix(in srgb, var(--soft) 54%, transparent); }
	.item__number { color: var(--accent); font-size: 12px; font-weight: 900; }
	.item h2 { margin: 0 0 7px; font-size: clamp(25px, 3vw, 42px); letter-spacing: -.07em; }
	.item p { margin: 0; color: rgb(47 41 30 / 68%); font-size: 14px; }
	.item__arrow { color: var(--accent); font-size: 28px; }
	footer { display: flex; justify-content: space-between; max-width: 1120px; margin: clamp(70px, 10vw, 140px) auto 0; padding-top: 20px; border-top: 1px solid rgb(47 41 30 / 20%); font-size: 12px; font-weight: 800; }
	footer p { margin: 0; letter-spacing: .14em; }
	footer a { border-bottom: 1px solid currentColor; }
	@keyframes reveal { from { opacity: 0; } }
	@keyframes rise { from { opacity: 0; transform: translateY(45px); } to { opacity: 1; transform: none; } }
	@media (max-width: 620px) {
		.category__header { align-items: flex-start; flex-direction: column; }
		.category__header nav { width: 100%; justify-content: space-between; }
		.category__hero { padding-top: 80px; }
		.category h1 { font-size: clamp(72px, 27vw, 120px); }
		.category__description { margin-left: 16%; }
		.item { grid-template-columns: 32px 1fr auto; }
	}
	@media (prefers-reduced-motion: reduce) { .category__header, .category__eyebrow, .category h1, .category__description, .item { animation: none; } }
</style>
