---
import Layout from '../../layouts/Layout.astro';
const { game } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const splitHighlights = (text) => {
  const phrases = game.highlights || [];
  const parts = [];
  let rest = text;
  while (rest) {
    let match = null;
    let matchIndex = -1;
    for (const phrase of phrases) {
      const index = rest.indexOf(phrase);
      if (index >= 0 && (matchIndex < 0 || index < matchIndex)) { match = phrase; matchIndex = index; }
    }
    if (!match) { parts.push({ text: rest, strong: false }); break; }
    if (matchIndex > 0) parts.push({ text: rest.slice(0, matchIndex), strong: false });
    parts.push({ text: match, strong: true });
    rest = rest.slice(matchIndex + match.length);
  }
  return parts;
};
---
<Layout title={game.title + ' | 코이노니아 마켓 놀거리'} description={game.tagline}>
<main class="hit-page">
<header class="topbar shell"><a href={base + '/play'}>← 놀거리 목록으로 돌아가기</a><span>HIT SERIES · GAME {game.number}</span></header>
<section class="poster shell"><img src={base + game.posterImage} alt={game.imageAlt} width={game.width} height={game.height} loading="eager" fetchpriority="high" /></section>
<section class="hero shell"><p>ARCADE MINI GAME</p><h1>{game.title}</h1><h2>{game.tagline}</h2></section>
<div class="content shell">
<section class="panel intro" aria-labelledby="intro-title"><div class="heading"><span>🎯</span><div><p>GAME INFO</p><h2 id="intro-title">게임 소개</h2></div></div><div class="prose">{game.intro.map((text) => <p>{splitHighlights(text).map((part) => part.strong ? <strong>{part.text}</strong> : part.text)}</p>)}</div>{game.example && <div class="example"><span>예시</span><strong>{game.example}</strong>{game.timerFormat && <small>{game.timerFormat}</small>}</div>}</section>
<section class="panel" aria-labelledby="steps-title"><div class="heading"><span>🕹️</span><div><p>HOW TO PLAY</p><h2 id="steps-title">게임 방법</h2></div></div><ol class="steps">{game.steps.map((text,index)=><li><span>{index+1}</span><p>{splitHighlights(text).map((part)=>part.strong?<strong>{part.text}</strong>:part.text)}</p></li>)}</ol></section>
{game.score && <section class="panel" aria-labelledby="score-title"><div class="heading"><span>📊</span><div><p>SCORE</p><h2 id="score-title">{game.score.title}</h2></div></div><ul class="feature-list">{game.score.items.map((text)=><li>{splitHighlights(text).map((part)=>part.strong?<strong>{part.text}</strong>:part.text)}</li>)}</ul></section>}
{game.successPatterns && <section class="panel" aria-labelledby="success-title"><div class="heading"><span>▦</span><div><p>SUCCESS</p><h2 id="success-title">성공 조건</h2></div></div><div class="pattern-grid">{game.successPatterns.map((pattern)=><article><div class={'egg-grid '+pattern.class}>{Array.from({length:16},(_,i)=><i class:list={{on:pattern.cells.includes(i)}}></i>)}</div><strong>{pattern.name}</strong></article>)}</div></section>}
{game.participation && <section class="panel" aria-labelledby="participation-title"><div class="heading"><span>🎟️</span><div><p>JOIN US</p><h2 id="participation-title">참여 안내</h2></div></div><dl class="participation">{game.participation.map((item)=><div><dt>{item.label}</dt><dd>{splitHighlights(item.value).map((part)=>part.strong?<strong>{part.text}</strong>:part.text)}</dd></div>)}</dl></section>}
{game.notices && <section class="panel notice" aria-labelledby="notice-title"><div class="heading"><span>!</span><div><p>PLEASE NOTE</p><h2 id="notice-title">주의사항</h2></div></div><ul>{game.notices.map((text)=><li>{splitHighlights(text).map((part)=>part.strong?<strong>{part.text}</strong>:part.text)}</li>)}</ul></section>}
<section class="panel prizes" aria-labelledby="prizes-title"><div class="heading"><span>🏆</span><div><p>PRIZES</p><h2 id="prizes-title">상품 안내</h2></div></div><div class:list={['prize-grid',{single:game.prizes.length===1}]}>{game.prizes.map((prize,index)=><article><span>{prize.icon || ['🥇','🥈','🥉'][index]}</span><small>{prize.label}</small><strong>{splitHighlights(prize.name).map((part)=>part.strong?<em>{part.text}</em>:part.text)}</strong></article>)}</div></section>
<a class="back" href={base + '/play'}>← 놀거리 목록으로 돌아가기</a>
</div></main></Layout>
<style>
:global(body){background:#edf7fc}.hit-page{--blue:#168fd0;--deep:#115b91;--orange:#f27a31;--ink:#17324b;--muted:#607486;--line:#d6e6ee;min-height:100svh;color:var(--ink);background:radial-gradient(circle at 10% 18%,#bdeaff55 0 90px,transparent 91px),linear-gradient(180deg,#dff5ff 0 720px,#f3f8fb 720px)}.shell{width:min(1040px,calc(100% - 40px));margin-inline:auto}.topbar{display:flex;justify-content:space-between;padding:22px 0;border-bottom:1px solid #5ba9d43d;font-size:12px;font-weight:850}.topbar a,.back{color:inherit;text-decoration:none}.topbar span{color:#4f7892}.poster{padding-top:34px}.poster img{display:block;width:100%;height:auto;max-height:680px;object-fit:contain;border-radius:22px;background:#fff;box-shadow:0 20px 50px #135a8420}.hero{padding:54px 0 66px;text-align:center}.hero>p,.heading p{margin:0 0 8px;color:var(--orange);font-size:10px;font-weight:950;letter-spacing:.15em}.hero h1{margin:0;color:var(--deep);font-size:clamp(48px,8vw,82px);line-height:1;letter-spacing:-.075em}.hero h2{margin:18px auto 0;max-width:760px;color:var(--muted);font-size:clamp(18px,2.7vw,26px);line-height:1.55;letter-spacing:-.035em}.content{display:grid;gap:22px;padding-bottom:80px}.panel{padding:clamp(27px,4vw,44px);border:1px solid var(--line);border-radius:24px;background:#fff;box-shadow:0 10px 28px #153d5710}.heading{display:flex;gap:14px;align-items:center;margin-bottom:25px}.heading>span{display:grid;width:54px;height:54px;flex:0 0 auto;place-items:center;border-radius:16px;color:#fff;background:linear-gradient(135deg,var(--blue),#65cbed);font-size:25px;font-weight:950}.heading h2{margin:0;font-size:clamp(29px,4vw,42px);letter-spacing:-.055em}.prose{display:grid;gap:10px}.prose p{margin:0;color:#435c70;font-size:17px;line-height:1.8}.panel strong,.panel em{color:var(--orange);font-style:normal;font-weight:950}.example{display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-top:22px;padding:20px;border:2px dashed #74bfe4;border-radius:16px;background:#eef9ff}.example span{padding:6px 10px;border-radius:999px;color:#fff;background:var(--orange);font-size:11px;font-weight:900}.example strong{font:950 clamp(24px,4vw,38px) ui-monospace,monospace}.example small{width:100%;color:var(--muted);font-size:13px}.steps{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin:0;padding:0;list-style:none}.steps li{display:grid;grid-template-columns:auto 1fr;gap:15px;min-height:112px;padding:20px;border:1px solid var(--line);border-radius:16px;background:#f8fbfd}.steps li>span{display:grid;width:42px;height:42px;place-items:center;border-radius:12px;color:#fff;background:var(--deep);font-size:20px;font-weight:950}.steps p{margin:3px 0 0;font-size:16px;line-height:1.65}.feature-list,.notice ul{display:grid;gap:10px;margin:0;padding:0;list-style:none}.feature-list li,.notice li{padding:16px 18px;border-left:4px solid var(--blue);border-radius:10px;background:#f3f9fc;font-size:16px;line-height:1.6}.notice{border-color:#f1c8ae;background:#fffaf6}.notice .heading>span{background:var(--orange)}.notice li{border-left-color:var(--orange);background:#fff}.participation{display:grid;grid-template-columns:repeat(3,1fr);margin:0;overflow:hidden;border:1px solid var(--line);border-radius:16px}.participation div{padding:20px;background:#f8fbfd}.participation div+div{border-left:1px solid var(--line)}.participation dt{margin-bottom:8px;color:var(--blue);font-size:11px;font-weight:900}.participation dd{margin:0;font-size:16px;font-weight:800;line-height:1.5}.prize-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.prize-grid.single{grid-template-columns:1fr}.prize-grid article{display:flex;min-height:180px;flex-direction:column;align-items:center;justify-content:center;padding:24px;border:1px solid #f0d3aa;border-radius:18px;background:linear-gradient(180deg,#fffaf0,#fff);text-align:center}.prize-grid article>span{font-size:45px}.prize-grid small{margin:10px 0 5px;color:#8c6e46;font-size:12px;font-weight:900}.prize-grid strong{color:var(--ink);font-size:clamp(18px,2.3vw,25px);line-height:1.45}.pattern-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.pattern-grid article{padding:20px;border:1px solid var(--line);border-radius:16px;background:#f8fbfd;text-align:center}.egg-grid{display:grid;grid-template-columns:repeat(4,34px);gap:6px;justify-content:center;margin-bottom:14px}.egg-grid i{width:34px;height:34px;border:2px solid #b8ccd8;border-radius:50%;background:#fff}.egg-grid i.on{border-color:var(--orange);background:var(--orange);box-shadow:inset 0 0 0 7px #ffd3b8}.pattern-grid strong{color:var(--deep)}.back{justify-self:start;padding:14px 19px;border-radius:12px;color:#fff;background:var(--deep);font-size:14px;font-weight:900}.back:hover{background:var(--orange)}
@media(max-width:720px){.shell{width:calc(100% - 24px)}.topbar{align-items:flex-start;flex-direction:column;gap:8px}.poster{padding-top:20px}.poster img{max-height:none;border-radius:14px}.hero{padding:40px 0 48px}.hero h1{font-size:clamp(43px,14vw,62px)}.hero h2{font-size:18px}.content{gap:16px;padding-bottom:55px}.panel{padding:24px 18px;border-radius:19px}.steps,.participation,.prize-grid{grid-template-columns:1fr}.steps li{min-height:0}.participation div+div{border-top:1px solid var(--line);border-left:0}.prize-grid article{min-height:150px}.pattern-grid{grid-template-columns:repeat(3,1fr)}.pattern-grid article{padding:14px 6px}.egg-grid{grid-template-columns:repeat(4,20px);gap:4px}.egg-grid i{width:20px;height:20px}.pattern-grid strong{font-size:13px}}
@media(max-width:420px){.pattern-grid{grid-template-columns:1fr}.egg-grid{grid-template-columns:repeat(4,30px)}.egg-grid i{width:30px;height:30px}}
</style>