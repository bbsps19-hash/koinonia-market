---
import Layout from '../../layouts/Layout.astro';
import { boardGames } from '../../data/boardGames.js';
const base=import.meta.env.BASE_URL.replace(/\/$/,'');
const filters=['전체','파티','전략','협력','블러핑','입문'];
const aliases={파티:['파티','그림','순발력','가족','상상력'],전략:['전략','엔진빌딩','드래프팅','조합','세트 모으기','베팅','트릭테이킹'],협력:['협력','팀워크','임무','힌트'],블러핑:['블러핑','마피아','심리전','정체 숨기기','진영전'],입문:['입문','초보 추천','쉬운 규칙','가벼움','짧은 플레이','빠른 진행']};
const games=boardGames.map(game=>({...game,imageUrl:`${base}${game.image}`,filters:Object.entries(aliases).filter(([,values])=>values.some(value=>game.tags.includes(value))).map(([key])=>key)}));
---
<Layout title="보드게임 추천 리스트 | 코이노니아 마켓" description="인원과 취향에 맞는 보드게임을 빠르게 골라보세요.">
<main class="page">
<header class="nav shell"><a href={`${base}/play`}>← 놀거리 목록으로</a><span>4청 선교마켓 · BOARD GAME</span></header>
<section class="hero shell"><p class="label">PICK YOUR GAME</p><h1>보드게임<br/><em>추천 리스트</em></h1><p>인원과 취향에 맞는 게임을 골라보세요. 게임 방법도 카드에서 바로 확인할 수 있어요.</p><div class="badges"><span>15가지 게임</span><span>30분 3,000원</span><span>1시간 5,000원</span></div></section>
<section class="list shell" aria-labelledby="games-title">
<div class="heading"><div><p class="label">CHOOSE YOUR STYLE</p><h2 id="games-title">어떤 게임을 찾으세요?</h2></div><strong id="count">전체 15개</strong></div>
<div class="filters" role="group" aria-label="보드게임 유형 필터">{filters.map((filter,index)=><button type="button" class:list={{active:index===0}} data-filter={filter} aria-pressed={index===0?'true':'false'}>{filter}</button>)}</div>
<div class="grid">{games.map((game,index)=><article class="card" data-card data-filters={game.filters.join(',')}>
<div class="image"><img src={game.imageUrl} alt={`${game.title} 보드게임 상자`} loading={index<4?'eager':'lazy'}/><span>{String(index+1).padStart(2,'0')}</span></div>
<div class="body"><h3>{game.title}</h3><div class="info"><span>인원 {game.players}</span><span>시간 {game.time}</span></div><div class="tags">{game.tags.map(tag=><span>#{tag}</span>)}</div><p class="summary">{game.summary}</p>
<details><summary>게임 방법 <b>열어보기</b></summary><ol>{game.howTo.map(step=><li>{step}</li>)}</ol></details>
<p class="point"><b>추천 포인트</b>{game.point}</p><a class="video" href={game.youtube} target="_blank" rel="noopener noreferrer">설명 영상 보기 <span>↗</span></a></div>
</article>)}</div><p id="empty" class="empty" hidden>이 유형의 게임을 준비 중이에요.</p>
</section>
<section class="rental shell"><div><p class="label">RENTAL INFO</p><h2>마음에 드는 게임을 골랐나요?</h2></div><dl><div><dt>이용 요금</dt><dd>30분 3,000원 / 1시간 5,000원</dd></div><div><dt>운영 장소</dt><dd>1층 큰숲홀 놀거리 부스</dd></div><div><dt>이용 안내</dt><dd>사용 후 구성품을 확인해 반납해주세요.</dd></div></dl></section>
<footer class="footer shell"><a href={`${base}/play`}>← 놀거리 목록으로</a><span>KOINONIA MARKET BOARD GAME</span></footer>
</main></Layout>
<script>
const buttons=[...document.querySelectorAll('[data-filter]')],cards=[...document.querySelectorAll('[data-card]')],count=document.querySelector('#count'),empty=document.querySelector('#empty');
buttons.forEach(button=>button.addEventListener('click',()=>{const selected=button.getAttribute('data-filter')||'전체';let visible=0;buttons.forEach(item=>{const active=item===button;item.classList.toggle('active',active);item.setAttribute('aria-pressed',String(active))});cards.forEach(card=>{const show=selected==='전체'||(card.getAttribute('data-filters')||'').split(',').includes(selected);card.toggleAttribute('hidden',!show);if(show)visible++});if(count)count.textContent=`${selected} ${visible}개`;if(empty instanceof HTMLElement)empty.hidden=visible!==0}))
</script>
<style>
:global(body){background:#f4ecdc}.page{--navy:#102d50;--orange:#e96f38;--paper:#fffdf8;--ink:#19283b;--muted:#687385;--line:#dfd8ca;min-height:100svh;color:var(--ink);background:linear-gradient(180deg,var(--navy) 0 510px,#f4ecdc 510px)}.shell{width:min(1240px,calc(100% - 40px));margin-inline:auto}.nav{display:flex;justify-content:space-between;padding:22px 0;border-bottom:1px solid #ffffff29;color:#fff;font-size:12px;font-weight:800}.nav a,.footer a{color:inherit;text-decoration:none}.nav span{color:#ffffff94}.hero{min-height:430px;padding:66px 0 90px;color:#fff}.label{margin:0 0 10px;color:#ff9a6c;font-size:10px;font-weight:900;letter-spacing:.16em}.hero h1{margin:0;font-size:clamp(52px,8vw,92px);line-height:.98;letter-spacing:-.075em}.hero h1 em{color:#ffd690;font-style:normal}.hero>p:not(.label){max-width:650px;margin:24px 0;color:#ffffffc2;font-size:17px;line-height:1.65}.badges,.info,.tags{display:flex;flex-wrap:wrap;gap:8px}.badges span{padding:8px 13px;border:1px solid #ffffff38;border-radius:999px;background:#ffffff12;font-size:12px;font-weight:800}.badges span:first-child{border-color:var(--orange);background:var(--orange)}.list{margin-top:-36px;padding:34px;border:1px solid var(--line);border-radius:24px;background:var(--paper);box-shadow:0 18px 50px #102d501f}.heading{display:flex;justify-content:space-between;align-items:end;gap:20px}.heading h2,.rental h2{margin:0;font-size:clamp(28px,4vw,42px);letter-spacing:-.055em}.heading strong{color:var(--muted);font-size:13px}.filters{display:flex;flex-wrap:wrap;gap:8px;margin:25px 0 30px;padding-bottom:22px;border-bottom:1px solid var(--line)}.filters button{padding:9px 15px;border:1px solid #d7dce1;border-radius:999px;color:#526072;background:#fff;cursor:pointer;font-size:13px;font-weight:800}.filters button.active{border-color:var(--navy);color:#fff;background:var(--navy)}.grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}.card{display:flex;min-width:0;overflow:hidden;flex-direction:column;border:1px solid #e0ddd5;border-radius:18px;background:#fff;box-shadow:0 8px 22px #102d5012}.card[hidden]{display:none}.image{position:relative;display:grid;height:250px;padding:18px;place-items:center;overflow:hidden;background:linear-gradient(145deg,#f4f0e8,#e8eef0)}.image img{width:100%;height:100%;object-fit:contain;filter:drop-shadow(0 9px 8px #102d5029)}.image>span{position:absolute;top:13px;left:13px;display:grid;width:34px;height:34px;place-items:center;border-radius:10px;color:#fff;background:var(--navy);font-size:10px;font-weight:900}.body{display:flex;flex:1;flex-direction:column;padding:22px}.body h3{margin:0 0 13px;font-size:24px;letter-spacing:-.045em}.info span{padding:7px 10px;border-radius:8px;color:var(--navy);background:#eaf2f5;font-size:11px;font-weight:800}.tags{gap:5px;margin-top:11px}.tags span{color:#88705c;font-size:11px;font-weight:700}.summary{margin:16px 0;color:var(--muted);font-size:13px;line-height:1.7}details{margin:0 0 15px;border:1px solid #e3ded4;border-radius:11px;background:#faf8f3}summary{display:flex;justify-content:space-between;padding:12px 13px;cursor:pointer;font-size:12px;font-weight:900;list-style:none}summary::-webkit-details-marker{display:none}summary b{color:var(--orange);font-size:10px}details[open] summary{border-bottom:1px solid #e3ded4}details ol{margin:0;padding:13px 15px 14px 32px;color:#596578;font-size:12px;line-height:1.65}details li+li{margin-top:6px}.point{margin:auto 0 15px;padding:13px;border-left:3px solid var(--orange);color:#4c5868;background:#fff7ef;font-size:12px;line-height:1.6}.point b{display:block;margin-bottom:3px;color:var(--orange);font-size:10px}.video{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-radius:10px;color:#fff;background:var(--navy);font-size:12px;font-weight:900;text-decoration:none}.video:hover{background:var(--orange)}.video span{font-size:16px}.empty{padding:60px;text-align:center}.rental{display:grid;grid-template-columns:.8fr 1.2fr;gap:50px;align-items:center;margin-top:34px;padding:40px;border-radius:22px;color:#fff;background:var(--navy)}.rental dl{display:grid;gap:10px;margin:0}.rental dl div{display:grid;grid-template-columns:90px 1fr;gap:14px;padding-bottom:10px;border-bottom:1px solid #ffffff21}.rental dt{color:#ffb68f;font-size:11px;font-weight:900}.rental dd{margin:0;color:#ffffffd1;font-size:13px}.footer{display:flex;justify-content:space-between;padding:32px 0;color:var(--navy);font-size:12px;font-weight:900}.footer span{color:#7f8790}@media(min-width:1180px){.grid{grid-template-columns:repeat(4,minmax(0,1fr))}.image{height:230px}}@media(max-width:820px){.grid{grid-template-columns:repeat(2,minmax(0,1fr))}.rental{grid-template-columns:1fr;gap:26px}}@media(max-width:560px){.page{background:linear-gradient(180deg,var(--navy) 0 550px,#f4ecdc 550px)}.shell{width:calc(100% - 24px)}.nav,.footer{align-items:flex-start;flex-direction:column;gap:8px}.hero{min-height:470px;padding:52px 0 76px}.hero h1{font-size:clamp(49px,15vw,68px)}.hero>p:not(.label){font-size:15px}.list{padding:22px 14px;border-radius:18px}.heading{align-items:flex-start;flex-direction:column;gap:9px}.filters{flex-wrap:nowrap;margin:20px -14px 24px;padding:0 14px 16px;overflow-x:auto}.filters button{flex:0 0 auto}.grid{grid-template-columns:1fr;gap:16px}.image{height:230px}.body{padding:19px}.summary{margin-block:14px}.rental{padding:28px 22px}.rental dl div{grid-template-columns:1fr;gap:4px}}
</style>
