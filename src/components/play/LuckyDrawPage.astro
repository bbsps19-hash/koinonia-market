---
import Layout from '../../layouts/Layout.astro';
import { luckyDraw } from '../../data/luckyDraw.js';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const tickets = Array.from({ length: 45 }, (_, i) => String(i + 1).padStart(2, '0'));
---
<Layout title={`${luckyDraw.title} | 코이노니아 마켓 놀거리`} description={luckyDraw.subtitle}>
<main class="page">
  <header class="nav shell"><a href={`${base}/play`}>← 놀거리 목록으로 돌아가기</a><span>4청 코이노니아 마켓 · 놀거리</span></header>
  <section class="hero shell" aria-labelledby="title">
    <div><p class="labels"><span>4청 코이노니아 마켓</span><b>놀거리</b></p><h1 id="title">{luckyDraw.title}</h1><h2>{luckyDraw.subtitle}</h2><strong class="price">{luckyDraw.price}</strong></div>
    <aside aria-hidden="true"><small>LUCKY</small><b>{luckyDraw.winnerCount}</b><span>WINNERS</span></aside>
  </section>

  <section class="poster-section shell" aria-labelledby="poster-title">
    <div class="poster-copy"><p class="eyebrow">LUCKY DRAW POSTER</p><h2 id="poster-title">{luckyDraw.boardName}</h2><p>새로 준비한 뽑기판과 상품 구성을 포스터에서 한눈에 확인해보세요.</p><strong>{luckyDraw.price}</strong></div>
    <figure><img src={base + luckyDraw.posterImage} alt={`${luckyDraw.title} 최신 상품 안내 포스터`} width="1055" height="1491" /></figure>
  </section>

  <section class="board-wrap shell" aria-labelledby="board-title">
    <div class="board-copy"><p class="eyebrow">PICK YOUR NUMBER</p><h2 id="board-title">{luckyDraw.boardName}</h2><p>한 장을 골라 번호를 열어보세요.<br/>작은 설렘 뒤에 반가운 선물이 기다리고 있어요.</p><span class="hint"><i></i> 번호표를 하나 골라 뽑아주세요</span></div>
    <div class="board" aria-label="번호표가 붙어 있는 추억의 뽑기판 일러스트">
      <div class="board-head"><small>오늘의 작은 행운</small><strong>{luckyDraw.boardName}</strong><span>번호를 뽑고 행운을 확인하세요</span></div>
      <div class="tickets" aria-hidden="true">{tickets.map((n,i)=><span class:list={{off:[5,17,31].includes(i)}}>{n}</span>)}</div>
      <div class="board-foot"><span>GOOD LUCK</span><b>{luckyDraw.price}</b></div>
    </div>
  </section>

  <section class="steps shell" aria-labelledby="steps-title">
    <div class="heading"><p>HOW TO PLAY</p><h2 id="steps-title">참여 방법</h2></div>
    <ol>{luckyDraw.steps.map((step,i)=><li><span>0{i+1}</span><i aria-hidden="true">{i===0?'▣':i===1?'⌕':'□'}</i><strong>{step}</strong></li>)}</ol>
  </section>

  <section class="prizes shell" aria-labelledby="prizes-title">
    <div class="prize-head"><div class="heading"><p>LUCKY PRIZES</p><h2 id="prizes-title">오늘의 상품</h2><span>문방구 앞 추억을 닮은 다섯 가지 행운을 준비했어요.</span></div><div class="total"><b>{luckyDraw.winnerCount}</b><span>명 당첨</span></div></div>
    <div class="prize-grid">{luckyDraw.prizes.map((prize,i)=><article class={`card c${i+1}`}><div class="rank"><span>{prize.rank}</span></div><div class={`art ${prize.image ? 'photo' : prize.type}`} aria-hidden="true">
      {prize.type==='voucher'&&<div class="voucher"><small>오헬모에드</small><b>1만원권</b><span>GIFT VOUCHER</span></div>}
      {prize.type==='keyrings'&&<div class="keyrings"><div class="doll-keyring"><i></i><span>인형</span></div><div class="clover-keyring"><i></i><span>클로버</span></div></div>}
      {prize.image && <img src={base + prize.image} alt={prize.name} loading="lazy" />}
    </div><h3>{prize.name}</h3><p class="winner-count"><b>{prize.winners}명</b> 당첨</p></article>)}</div>
  </section>

  <section class="closing shell"><div><p>EVERY PICK, A LITTLE JOY</p><h2>총 당첨자 <strong>{luckyDraw.winnerCount}명!</strong></h2></div><ul>{luckyDraw.notices.map(n=><li>{n}</li>)}</ul></section>
  <footer class="footer shell"><a href={`${base}/play`}>← 놀거리 목록으로 돌아가기</a><span>KOINONIA MARKET PLAY ZONE</span></footer>
</main>
</Layout>

<style>
:global(body){background:#f4ede2}.page{--paper:#fffdf9;--brown:#3e2a24;--muted:#76675e;--red:#b83d32;--line:#e5d9c9;min-height:100svh;overflow:hidden;color:var(--brown);background:linear-gradient(180deg,#f6eee2 0 650px,#fffaf3 650px)}.shell{width:min(1120px,calc(100% - 40px));margin-inline:auto}.nav{display:flex;justify-content:space-between;padding:22px 0;border-bottom:1px solid #8f746b35;font-size:12px;font-weight:800}.nav a,.footer a{color:inherit;text-decoration:none}.nav span,.footer span{color:#8b776d}.hero{position:relative;display:grid;grid-template-columns:1fr auto;align-items:center;min-height:560px;padding:80px 0 105px}.labels{display:flex;gap:8px;margin:0 0 25px}.labels span,.labels b{padding:8px 12px;border-radius:999px;font-size:11px}.labels span{color:white;background:var(--brown)}.labels b{border:1px solid #cdaea2;color:var(--red);background:#fff9f1}.hero h1{margin:0;font-family:'Gowun Dodum',sans-serif;font-size:clamp(62px,10vw,122px);font-weight:400;line-height:.98;letter-spacing:-.085em}.hero h2{margin:27px 0;color:var(--muted);font-size:clamp(18px,2.4vw,26px);font-weight:600;letter-spacing:-.04em}.price{display:inline-flex;padding:13px 20px;border-radius:12px;color:white;background:var(--red);box-shadow:5px 6px 0 #d8b8aa;font-size:18px;transform:rotate(-1deg)}.hero aside{display:grid;width:190px;height:190px;place-content:center;border:1px solid #c9aa9d;border-radius:50%;background:#fffaf2;box-shadow:0 20px 50px #71483a18;text-align:center;transform:rotate(5deg)}.hero aside small,.hero aside span{color:var(--red);font-size:10px;font-weight:900;letter-spacing:.16em}.hero aside b{font-family:'Gowun Dodum';font-size:70px;font-weight:400;line-height:1}.poster-section{display:grid;grid-template-columns:.72fr 1.28fr;gap:clamp(36px,7vw,90px);align-items:center;margin-bottom:90px;padding:clamp(28px,5vw,58px);border-radius:30px;color:#fff;background:var(--brown);box-shadow:0 24px 60px #563c2c20}.poster-copy h2{margin:0;font-size:clamp(38px,5vw,62px);letter-spacing:-.065em}.poster-copy>p:not(.eyebrow){margin:22px 0;color:#ffffffbf;font-size:15px;line-height:1.8}.poster-copy>strong{display:inline-flex;padding:11px 16px;border-radius:10px;color:var(--brown);background:#f2bd9f;font-size:16px}.poster-section figure{margin:0;overflow:hidden;border:8px solid #fff;border-radius:18px;background:#fff;box-shadow:9px 11px 0 #b83d32;transform:rotate(1deg)}.poster-section img{display:block;width:100%;height:auto}.board-wrap{display:grid;grid-template-columns:.72fr 1.28fr;gap:clamp(40px,8vw,100px);align-items:center;padding:80px clamp(28px,6vw,78px);border:1px solid var(--line);border-radius:30px;background:var(--paper);box-shadow:0 24px 60px #563c2c12}.eyebrow,.heading>p,.closing>div>p{margin:0 0 10px;color:var(--red);font-size:10px;font-weight:900;letter-spacing:.16em}.board-copy h2,.heading h2,.closing h2{margin:0;font-size:clamp(34px,5vw,58px);line-height:1.08;letter-spacing:-.065em}.board-copy>p:not(.eyebrow){margin:23px 0;color:var(--muted);font-size:15px;line-height:1.85}.hint{display:flex;gap:9px;align-items:center;color:#88766c;font-size:12px;font-weight:700}.hint i{width:18px;height:18px;border:2px solid white;border-radius:3px;background:var(--red);box-shadow:0 0 0 1px #c5aa9e}.board{width:min(100%,560px);padding:18px;border:2px solid #7f5043;border-radius:18px;background:#eadcc8;box-shadow:10px 12px 0 #dbc5ac,0 24px 50px #59403324;transform:rotate(1deg)}.board-head{padding:19px;border-radius:11px 11px 4px 4px;color:white;background:var(--red);text-align:center}.board-head small,.board-head span{display:block;font-size:9px;font-weight:800;letter-spacing:.1em;opacity:.82}.board-head strong{display:block;margin:4px;font-family:'Gowun Dodum';font-size:clamp(29px,4vw,43px);font-weight:400}.tickets{display:grid;grid-template-columns:repeat(9,1fr);gap:6px;padding:16px 4px;background:#f4eadb}.tickets span{display:grid;aspect-ratio:1/.78;place-items:center;border:1px solid #c8ab99;border-radius:3px;color:#70483d;background:#fffaf1;box-shadow:1px 2px 0 #d6c0aa;font:800 10px ui-monospace}.tickets span:nth-child(3n){transform:rotate(2deg)}.tickets span:nth-child(4n){transform:rotate(-2deg)}.tickets .off{color:#af8e81;background:#e5d5c5;text-decoration:line-through;box-shadow:none}.board-foot{display:flex;justify-content:space-between;align-items:center;padding:13px 9px 2px;color:#7b5d52;font-size:9px;font-weight:900;letter-spacing:.13em}.board-foot b{padding:6px 9px;border-radius:5px;color:white;background:var(--brown);font-size:11px;letter-spacing:0}.steps{padding:115px 0 105px}.steps ol{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:38px 0 0;padding:0;list-style:none}.steps li{position:relative;display:grid;grid-template-columns:auto 1fr;gap:18px;align-items:center;min-height:145px;padding:24px;border:1px solid var(--line);border-radius:18px;background:white}.steps li>span{position:absolute;top:15px;right:17px;color:#cbb7a5;font-size:11px;font-weight:900}.steps li>i{display:grid;width:62px;height:62px;place-items:center;border-radius:18px;color:white;background:var(--red);font-size:29px;font-style:normal}.steps strong{font-size:18px}.prizes{padding-bottom:115px}.prize-head{display:flex;align-items:end;justify-content:space-between;margin-bottom:42px}.heading>span{display:block;max-width:680px;margin-top:14px;color:var(--muted);font-size:14px}.total{display:flex;align-items:baseline;gap:6px;padding:15px 20px;border:1px solid #d6bdb1;border-radius:14px;color:var(--red);background:#fff8f0}.total b{font-size:34px}.total span{font-size:13px;font-weight:900}.prize-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px}.card{display:flex;min-height:330px;flex-direction:column;padding:24px;border:1px solid var(--line);border-radius:20px;background:white;box-shadow:0 12px 30px #543b2b0b}.c1,.c2{grid-column:span 3}.c3,.c4,.c5{grid-column:span 2;min-height:300px}.rank{display:flex;justify-content:space-between}.rank span{padding:6px 10px;border-radius:999px;color:white;background:var(--red);font-size:11px;font-weight:900}.rank b{color:var(--red);font-size:13px}.art{display:grid;flex:1;min-height:135px;place-items:center;margin:18px 0;border-radius:15px;background:#f8f1e7}.voucher{display:flex;width:min(90%,260px);height:105px;flex-direction:column;justify-content:center;padding:20px;border-radius:10px;color:white;background:linear-gradient(135deg,#8f2b25,#c85a49);box-shadow:7px 8px 0 #ddc1ad}.voucher small{font-size:11px;font-weight:900}.voucher b{font-size:28px}.voucher span{font-size:9px;font-weight:900;letter-spacing:.14em}.keyrings{display:flex;gap:28px;align-items:center;justify-content:center}.keyrings>div{display:grid;gap:7px;justify-items:center;color:var(--brown);font-size:11px;font-weight:900}.keyrings i{position:relative;display:block;width:72px;height:72px}.doll-keyring i{border:8px solid #dfae7e;border-radius:46% 46% 42% 42%;background:#f1c89d;box-shadow:inset 0 -12px 0 #b96956}.doll-keyring i:before,.doll-keyring i:after{position:absolute;top:-15px;width:28px;height:30px;border-radius:50%;background:#dfae7e;content:""}.doll-keyring i:before{left:-8px}.doll-keyring i:after{right:-8px}.clover-keyring i:before{position:absolute;inset:0;background:radial-gradient(circle at 27% 27%,#68a362 0 24%,transparent 25%),radial-gradient(circle at 73% 27%,#68a362 0 24%,transparent 25%),radial-gradient(circle at 27% 73%,#68a362 0 24%,transparent 25%),radial-gradient(circle at 73% 73%,#68a362 0 24%,transparent 25%);content:""}.clover-keyring i:after{position:absolute;right:-4px;bottom:-18px;width:9px;height:38px;border-radius:9px;background:#477d48;content:"";transform:rotate(-34deg)}.art.photo{background:transparent}.art>img{display:block;width:100%;height:150px;object-fit:contain;border-radius:12px}.dalgona{display:grid;width:110px;height:110px;place-items:center;border:8px solid #c7843c;border-radius:50%;color:#a9652e;background:#dba257;font-size:48px}.snack,.candy{display:flex;gap:7px;align-items:center}.snack i{width:35px;height:70px;border:10px solid #bd7136;border-radius:50%;transform:rotate(25deg)}.snack i:nth-child(2){transform:translateY(-12px) rotate(-18deg)}.candy i{display:grid;width:44px;height:70px;place-items:center;border:3px solid white;border-radius:20px;color:white;background:#cf493f;font-size:25px;font-style:normal;font-weight:900}.candy i:nth-child(2){background:#4b8b60}.candy i:nth-child(3){background:#e18c35}.card h3{margin:0;font-size:clamp(17px,2vw,23px);line-height:1.4;letter-spacing:-.045em}.card>p{margin:9px 0 0;color:var(--muted);font-size:11px;line-height:1.55}.winner-count{display:flex;align-items:baseline;gap:5px}.winner-count b{color:var(--red);font-size:20px}.closing{display:flex;gap:40px;align-items:center;justify-content:space-between;padding:44px clamp(28px,5vw,60px);border-radius:24px;color:white;background:var(--brown)}.closing>div>p{color:#e4b7a2}.closing h2{font-size:clamp(26px,4vw,43px)}.closing h2 strong{color:#f2bd9f}.closing ul{display:grid;gap:9px;min-width:330px;margin:0;padding:0;list-style:none}.closing li{padding:10px 13px;border:1px solid #ffffff21;border-radius:9px;color:#ffffffc7;font-size:12px}.footer{display:flex;justify-content:space-between;padding:34px 0;font-size:12px;font-weight:850}
@media(max-width:850px){.poster-section{grid-template-columns:1fr}.poster-copy{text-align:center}.poster-section figure{width:min(100%,560px);margin-inline:auto}.hero{grid-template-columns:1fr}.hero aside{position:absolute;right:0;bottom:55px;width:130px;height:130px;opacity:.5}.hero aside b{font-size:48px}.board-wrap{grid-template-columns:1fr}.board-copy{text-align:center}.hint{justify-content:center}.prize-grid{grid-template-columns:repeat(2,1fr)}.c1,.c2,.c3,.c4{grid-column:span 1}.c5{grid-column:1/-1}.closing{align-items:flex-start;flex-direction:column}.closing ul{width:100%;min-width:0}}
@media(max-width:600px){.poster-section{margin-bottom:55px;padding:26px 16px;border-radius:22px}.poster-section figure{border-width:5px;box-shadow:5px 7px 0 #b83d32}.keyrings{gap:18px}.shell{width:calc(100% - 24px)}.nav{align-items:flex-start;flex-direction:column;gap:8px}.hero{min-height:510px;padding:55px 0 75px}.hero h1{font-size:clamp(56px,18vw,82px)}.hero h2{max-width:270px;font-size:17px;line-height:1.6}.hero aside{right:-28px}.board-wrap{padding:45px 14px;border-radius:22px}.board{padding:10px;box-shadow:5px 7px 0 #dbc5ac}.tickets{grid-template-columns:repeat(7,1fr);gap:4px;padding:10px 2px}.steps{padding:85px 0 80px}.steps ol{grid-template-columns:1fr;gap:10px}.steps li{min-height:110px}.prize-head{align-items:flex-start;flex-direction:column;gap:24px}.total{align-self:stretch;justify-content:center}.prize-grid{grid-template-columns:1fr}.c1,.c2,.c3,.c4,.c5{grid-column:auto;min-height:285px}.closing{padding:32px 22px}.footer{align-items:flex-start;flex-direction:column;gap:10px}}
</style>
