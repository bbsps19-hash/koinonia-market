---
import Layout from '../../layouts/Layout.astro';
import { playGames } from '../../data/play.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const game = playGames.find((item) => item.id === 'cup-battle');
const steps = [
  { before: '턴을 잡은 팀은 ', emphasis: '풍선을 공중에 띄웁니다.', after: '' },
  { before: '풍선이 떨어지기 전까지, ', emphasis: '내 컵으로 상대팀 컵을 덮어씌웁니다.', after: '' },
  { before: '풍선이 바닥에 떨어지기 전에 잡아야 하고 ', emphasis: '턴을 교대합니다.', after: '' },
  { before: '풍선이 바닥에 떨어지면 ', emphasis: '즉시 패배', after: '하니 유의하여야 합니다.' },
];
---

<Layout title="컵 땅따먹기 대항전 | 코이노니아 마켓 놀거리" description="누가 더 빨리 상대팀 컵을 차지할까?">
  <main class="cup-page">
    <section class="poster"><img src={base + game.posterImage} alt="컵 땅따먹기 대항전 안내 포스터" width="1672" height="941" /></section>
    <header class="hero shell">
      <a href={base + '/play'}>← 놀거리 목록으로 돌아가기</a>
      <div class="team-labels" aria-hidden="true"><span>🎈 하늘팀</span><b>VS</b><span>노랑팀 🎈</span></div>
      <h1>컵 땅따먹기 대항전!</h1><p>누가 더 빨리 상대팀 컵을 차지할까?</p>
    </header>
    <div class="content shell">
      <section class="info section-card" aria-labelledby="info-title">
        <div class="section-heading"><span aria-hidden="true">🎈🥤</span><div><p>TEAM &amp; ITEMS</p><h2 id="info-title">인원 및 준비물</h2></div></div>
        <div class="info-grid"><article><span>👥</span><strong>팀별(하늘/노랑) 1~3명</strong></article><article><span>🎈</span><strong>각 팀 색상의 풍선 1개와 종이컵 28개</strong></article></div>
        <aside class="ticket-box"><span aria-hidden="true">🎟️</span><div><strong>인원 상관없이 팀별 티켓 1장 필요</strong><b>총 2장</b></div></aside>
      </section>
      <section class="rules section-card" aria-labelledby="rules-title">
        <div class="section-heading"><span aria-hidden="true">🏁</span><div><p>HOW TO PLAY</p><h2 id="rules-title">게임 진행</h2></div></div>
        <ol>{steps.map((step, index) => <li><span>{index + 1}</span><p>{step.before}<strong>{step.emphasis}</strong>{step.after}</p></li>)}</ol>
      </section>
      <section class="results section-card" aria-labelledby="results-title">
        <div class="section-heading"><span aria-hidden="true">🏆</span><div><p>WIN &amp; PRIZES</p><h2 id="results-title">승리 및 시상</h2></div></div>
        <article class="condition"><span>🏆</span><div><h3>승리 조건</h3><p>상대팀 컵을 모두 덮어 <strong>내 팀 컵만 남기면 승리</strong>합니다.</p></div></article>
        <div class="award-grid"><article class="winner"><span>🎁</span><h3>승리 팀</h3><strong>상품 지급</strong></article><article class="loser"><span>🍪</span><h3>패배 팀</h3><strong>간식 지급</strong></article></div>
      </section>
    </div>
  </main>
</Layout>

<style>
:global(body){background:#f5f6f8}.cup-page{--blue:#397aa8;--blue-soft:#eaf2f7;--yellow:#e3b93e;--yellow-soft:#faf4df;--ink:#253446;--muted:#667382;--line:#dde2e7;min-height:100svh;color:var(--ink);background:#f5f6f8}.shell{width:min(1040px,calc(100% - 40px));margin-inline:auto}.poster{width:min(1240px,100%);margin-inline:auto;padding:clamp(10px,1.5vw,18px);background:#eceff2}.poster img{display:block;width:100%;height:auto;max-height:none;object-fit:contain;border-radius:14px;background:white;box-shadow:0 8px 28px #26374718}.hero{padding:34px 0 58px;text-align:center}.hero>a{display:inline-block;margin-bottom:34px;color:var(--muted);font-size:14px;font-weight:800;text-decoration:none}.team-labels{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:20px}.team-labels span{padding:8px 14px;border:1px solid #bfd4e1;border-radius:999px;color:#315f7e;background:var(--blue-soft);font-size:14px;font-weight:850}.team-labels span:last-child{border-color:#e6d69f;color:#756019;background:var(--yellow-soft)}.team-labels b{color:#89939e;font-size:15px}.hero h1{margin:0;font-size:clamp(42px,6vw,70px);font-weight:900;line-height:1.1;letter-spacing:-.065em}.hero p{margin:18px 0 0;color:var(--muted);font-size:clamp(19px,2.5vw,26px);font-weight:700;letter-spacing:-.03em}.content{display:grid;gap:22px;padding-bottom:72px}.section-card{padding:clamp(26px,4vw,44px);border:1px solid var(--line);border-radius:22px;background:#fff;box-shadow:0 8px 24px #2637470b}.section-heading{display:flex;gap:14px;align-items:center;margin-bottom:26px}.section-heading>span{display:grid;width:54px;height:54px;flex:0 0 auto;place-items:center;border-radius:15px;background:#f0f3f5;font-size:25px}.section-heading p{margin:0 0 4px;color:#758391;font-size:10px;font-weight:900;letter-spacing:.13em}.section-heading h2{margin:0;font-size:clamp(30px,4vw,42px);letter-spacing:-.055em}.info-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.info-grid article{display:flex;gap:14px;align-items:center;min-height:96px;padding:20px;border:1px solid var(--line);border-radius:16px;background:#fafbfc}.info-grid span{font-size:30px}.info-grid strong{font-size:clamp(16px,1.8vw,19px);line-height:1.55}.ticket-box{display:flex;gap:18px;align-items:center;margin-top:14px;padding:22px 24px;border:1px solid #cbd8e0;border-radius:16px;background:#f1f6f9}.ticket-box>span{font-size:36px}.ticket-box div{display:flex;flex:1;align-items:center;justify-content:space-between;gap:18px}.ticket-box strong{font-size:clamp(17px,2vw,21px);line-height:1.45}.ticket-box b{flex:0 0 auto;padding:10px 17px;border-radius:10px;color:white;background:#4d718a;font-size:clamp(20px,2.5vw,26px)}.rules ol{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin:0;padding:0;list-style:none}.rules li{display:grid;grid-template-columns:auto 1fr;gap:16px;align-items:start;min-height:138px;padding:22px;border:1px solid var(--line);border-radius:16px;background:#fafbfc}.rules li>span{display:grid;width:46px;height:46px;place-items:center;border-radius:12px;color:white;background:#617d91;font-size:24px;font-weight:900}.rules li p{margin:3px 0 0;font-size:clamp(16px,1.8vw,19px);font-weight:600;line-height:1.7}.rules li strong{font-weight:900}.condition{display:flex;gap:18px;align-items:center;padding:24px;border:1px solid #cbd8e0;border-radius:16px;background:#f1f6f9}.condition>span{font-size:38px}.condition h3,.award-grid h3{margin:0 0 7px;font-size:17px}.condition p{margin:0;font-size:clamp(17px,2vw,22px);line-height:1.55}.award-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-top:12px}.award-grid article{padding:25px;border:1px solid var(--line);border-radius:16px;background:#fafbfc;text-align:center}.award-grid span{display:block;margin-bottom:10px;font-size:42px}.award-grid h3{font-size:18px}.award-grid strong{color:#3d5c72;font-size:clamp(24px,3vw,34px)}.loser strong{color:#76652d}
@media(max-width:700px){.shell{width:calc(100% - 24px)}.poster{padding:6px}.poster img{border-radius:9px}.hero{padding:24px 0 42px}.hero>a{margin-bottom:25px;font-size:13px}.team-labels{gap:7px}.team-labels span{padding:7px 9px;font-size:12px}.hero h1{font-size:clamp(36px,11vw,52px)}.hero p{font-size:18px;line-height:1.5}.content{gap:15px;padding-bottom:45px}.section-card{padding:23px 17px;border-radius:18px}.section-heading{margin-bottom:20px}.section-heading>span{width:48px;height:48px;border-radius:13px;font-size:23px}.info-grid,.rules ol,.award-grid{grid-template-columns:1fr}.info-grid article{min-height:86px}.ticket-box{align-items:flex-start;padding:19px 17px}.ticket-box div{align-items:flex-start;flex-direction:column;gap:12px}.ticket-box b{align-self:stretch;text-align:center}.rules li{min-height:0;padding:19px 16px}.rules li>span{width:43px;height:43px;font-size:22px}.condition{align-items:flex-start;padding:20px 17px}.condition>span{font-size:32px}.award-grid article{padding:22px 17px}}
</style>
