---
import Layout from '../../layouts/Layout.astro';
import { playGames } from '../../data/play.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const game = playGames.find((item) => item.id === 'cup-battle');
const steps = [
  { before: '턴을 잡은 팀은 ', emphasis: '풍선을 공중에 띄웁니다.', after: '' },
  { before: '풍선이 떨어지기 전까지, ', emphasis: '내 컵으로 상대팀 컵을 덮어씌웁니다.', after: '' },
  { before: '풍선이 바닥에 떨어지기 전에 잡아야 하고 ', emphasis: '턴을 교대합니다.', after: '' },
  { before: '풍선이 바닥에 떨어지면 ', emphasis: '즉시 패배', after: '하니 유의하여야 합니다.' },
];
---

<Layout title="컵 땅따먹기 대항전 | 코이노니아 마켓 놀거리" description="누가 더 빨리 상대팀 컵을 차지할까?">
  <main class="cup-page">
    <section class="poster"><img src={base + game.posterImage} alt="컵 땅따먹기 대항전 안내 포스터" width="1672" height="941" /></section>
    <header class="hero shell">
      <a href={base + '/play'}>← 놀거리 목록으로 돌아가기</a>
      <div class="team-labels" aria-hidden="true"><span>🎈 하늘팀</span><b>VS</b><span>노랑팀 🎈</span></div>
      <h1>컵 땅따먹기 대항전!</h1><p>누가 더 빨리 상대팀 컵을 차지할까?</p>
    </header>
    <div class="content shell">
      <section class="info section-card" aria-labelledby="info-title">
        <div class="section-heading"><span aria-hidden="true">🎈🥤</span><div><p>TEAM &amp; ITEMS</p><h2 id="info-title">인원 및 준비물</h2></div></div>
        <div class="info-grid"><article><span>👥</span><strong>팀별(하늘/노랑) 1~3명</strong></article><article><span>🎈</span><strong>각 팀 색상의 풍선 1개와 종이컵 28개</strong></article></div>
        <aside class="ticket-box"><span aria-hidden="true">🎟️</span><div><strong>인원 상관없이 팀별 티켓 1장 필요</strong><b>총 2장</b></div></aside>
      </section>
      <section class="rules section-card" aria-labelledby="rules-title">
        <div class="section-heading"><span aria-hidden="true">🏁</span><div><p>HOW TO PLAY</p><h2 id="rules-title">게임 진행</h2></div></div>
        <ol>{steps.map((step, index) => <li><span>{index + 1}</span><p>{step.before}<strong>{step.emphasis}</strong>{step.after}</p></li>)}</ol>
      </section>
      <section class="results section-card" aria-labelledby="results-title">
        <div class="section-heading"><span aria-hidden="true">🏆</span><div><p>WIN &amp; PRIZES</p><h2 id="results-title">승리 및 시상</h2></div></div>
        <article class="condition"><span>🏆</span><div><h3>승리 조건</h3><p>상대팀 컵을 모두 덮어 <strong>내 팀 컵만 남기면 승리</strong>합니다.</p></div></article>
        <div class="award-grid"><article class="winner"><span>🎁</span><h3>승리 팀</h3><strong>상품 지급</strong></article><article class="loser"><span>🍪</span><h3>패배 팀</h3><strong>간식 지급</strong></article></div>
      </section>
    </div>
  </main>
</Layout>

<style>
:global(body){background:#f4fbff}.cup-page{--sky:#1598db;--sky-dark:#0873b5;--yellow:#ffd632;--yellow-dark:#e4aa00;--ink:#18304e;--muted:#5c718a;min-height:100svh;color:var(--ink);background:linear-gradient(135deg,#edfaff 0 50%,#fffbe3 50%)}.shell{width:min(1100px,calc(100% - 40px));margin-inline:auto}.poster{width:min(1440px,100%);margin-inline:auto;padding:clamp(12px,2vw,24px);background:linear-gradient(90deg,var(--sky),var(--yellow))}.poster img{display:block;width:100%;height:auto;max-height:none;object-fit:contain;border-radius:clamp(12px,2vw,24px);background:white;box-shadow:0 18px 50px #0f4f7a2e}.hero{padding:34px 0 68px;text-align:center}.hero>a{display:inline-block;margin-bottom:36px;color:var(--ink);font-size:14px;font-weight:850;text-decoration:none}.team-labels{display:flex;align-items:center;justify-content:center;gap:14px;margin-bottom:22px}.team-labels span{padding:10px 16px;border-radius:999px;color:white;background:var(--sky);font-size:15px;font-weight:900}.team-labels span:last-child{color:var(--ink);background:var(--yellow)}.team-labels b{font-size:20px}.hero h1{margin:0;font-size:clamp(44px,7vw,82px);font-weight:950;line-height:1.05;letter-spacing:-.07em}.hero p{margin:20px 0 0;color:var(--muted);font-size:clamp(20px,3vw,30px);font-weight:800;letter-spacing:-.035em}.content{display:grid;gap:28px;padding-bottom:80px}.section-card{padding:clamp(26px,5vw,52px);border:2px solid #d9e9f0;border-radius:30px;background:#ffffffed;box-shadow:0 16px 40px #184b6d12}.section-heading{display:flex;gap:16px;align-items:center;margin-bottom:30px}.section-heading>span{display:grid;width:64px;height:64px;flex:0 0 auto;place-items:center;border-radius:20px;background:#e6f7ff;font-size:30px}.section-heading p{margin:0 0 5px;color:var(--sky-dark);font-size:11px;font-weight:950;letter-spacing:.14em}.section-heading h2{margin:0;font-size:clamp(32px,5vw,50px);letter-spacing:-.06em}.info-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.info-grid article{display:flex;gap:16px;align-items:center;min-height:105px;padding:22px;border-radius:20px;background:#eefaff}.info-grid article:last-child{background:#fff7c9}.info-grid span{font-size:34px}.info-grid strong{font-size:clamp(17px,2vw,21px);line-height:1.55}.ticket-box{display:flex;gap:20px;align-items:center;margin-top:18px;padding:24px 28px;border:3px dashed var(--sky);border-radius:22px;background:linear-gradient(100deg,#e5f7ff,#fff5b8)}.ticket-box>span{font-size:42px}.ticket-box div{display:flex;flex:1;align-items:center;justify-content:space-between;gap:20px}.ticket-box strong{font-size:clamp(18px,2.5vw,25px);line-height:1.45}.ticket-box b{flex:0 0 auto;padding:12px 20px;border-radius:14px;color:white;background:var(--sky-dark);font-size:clamp(22px,3vw,32px)}.rules ol{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin:0;padding:0;list-style:none}.rules li{display:grid;grid-template-columns:auto 1fr;gap:18px;align-items:start;min-height:150px;padding:24px;border-radius:22px;background:#eefaff}.rules li:nth-child(even){background:#fff7c9}.rules li>span{display:grid;width:54px;height:54px;place-items:center;border-radius:16px;color:white;background:var(--sky);font-size:30px;font-weight:950}.rules li:nth-child(even)>span{color:var(--ink);background:var(--yellow)}.rules li p{margin:6px 0 0;font-size:clamp(17px,2vw,21px);font-weight:650;line-height:1.65}.rules li strong{font-weight:950}.condition{display:flex;gap:20px;align-items:center;padding:26px;border-radius:22px;color:white;background:linear-gradient(110deg,var(--sky-dark),var(--sky))}.condition>span{font-size:44px}.condition h3,.award-grid h3{margin:0 0 8px;font-size:18px}.condition p{margin:0;font-size:clamp(18px,2.5vw,25px);line-height:1.55}.award-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:16px}.award-grid article{padding:28px;border-radius:22px;text-align:center}.award-grid span{display:block;margin-bottom:12px;font-size:50px}.award-grid h3{font-size:20px}.award-grid strong{font-size:clamp(26px,4vw,40px)}.winner{background:#e7f7ff}.winner strong{color:var(--sky-dark)}.loser{background:#fff4b2}.loser strong{color:#a77800}
@media(max-width:700px){.shell{width:calc(100% - 24px)}.poster{padding:8px}.poster img{border-radius:10px}.hero{padding:25px 0 46px}.hero>a{margin-bottom:26px;font-size:13px}.team-labels{gap:8px}.team-labels span{padding:8px 10px;font-size:12px}.hero h1{font-size:clamp(38px,12vw,56px)}.hero p{font-size:19px;line-height:1.5}.content{gap:18px;padding-bottom:48px}.section-card{padding:24px 18px;border-radius:22px}.section-heading{margin-bottom:22px}.section-heading>span{width:52px;height:52px;border-radius:16px;font-size:25px}.info-grid,.rules ol,.award-grid{grid-template-columns:1fr}.info-grid article{min-height:92px}.ticket-box{align-items:flex-start;padding:20px 18px}.ticket-box div{align-items:flex-start;flex-direction:column;gap:14px}.ticket-box b{align-self:stretch;text-align:center}.rules li{min-height:0;padding:20px 17px}.rules li>span{width:48px;height:48px;font-size:25px}.condition{align-items:flex-start;padding:22px 18px}.condition>span{font-size:36px}.award-grid article{padding:24px 18px}}
</style>
