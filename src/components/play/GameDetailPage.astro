---
import Layout from '../../layouts/Layout.astro';
const { game } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const mediaSrc = game.mediaSrc ? `${base}${game.mediaSrc}` : null;
const isCupBattle = game.id === 'cup-battle';
const badges = isCupBattle ? ['팀 대항', '하늘팀 VS 노랑팀', game.price, '상위 3팀 시상'] : [game.price, game.location, game.time];
---

<Layout title={`${game.title} | 코이노니아 마켓 놀거리`} description={game.description}>
  <main class:list={['detail-page', `accent-${game.accent}`, { 'cup-page': isCupBattle }]}>
    <header class="detail-nav shell">
      <a href={`${base}/play`}>← 놀거리 목록으로 돌아가기</a>
      <span>4청 선교마켓 · GAME {game.number}</span>
    </header>

    <section class="detail-hero shell">
      <div class="speed-lines" aria-hidden="true"></div>
      <div class="hero-content">
        <p class="game-label">PLAY ZONE · {game.number}</p>
        <h1>{game.title}</h1>
        <p class="tagline">{game.shortDescription}</p>
        <div class="badge-row">{badges.map((badge) => <span>{badge}</span>)}</div>
      </div>
      <div class="versus-mark" aria-hidden="true"><span>{game.icon}</span></div>
    </section>

    {game.mediaType === 'video' && mediaSrc && (
      <section class="media-section shell" aria-labelledby="media-title">
        <div class="section-title"><p>HOW TO PLAY</p><h2 id="media-title">영상으로 먼저 만나보세요</h2><span>예시 영상을 보고 게임 방식을 빠르게 확인해보세요.</span></div>
        <div class="video-frame">
          <video src={mediaSrc} controls playsinline preload="metadata" aria-label={`${game.title} 게임 방법 예시 영상`}></video>
          <div class="team-tabs" aria-hidden="true"><span>SKY TEAM</span><b>VS</b><span>YELLOW TEAM</span></div>
        </div>
      </section>
    )}

    <div class="content-shell shell">
      <section class="intro-card info-card" aria-labelledby="intro-title">
        <span class="card-kicker">ABOUT GAME</span><h2 id="intro-title">게임 소개</h2><p>{game.description}</p>
      </section>

      {game.peopleAndItems && (
        <section class="items-section" aria-labelledby="items-title">
          <div class="section-title dark"><p>READY</p><h2 id="items-title">인원 및 준비물</h2></div>
          <ul class="item-grid">{game.peopleAndItems.map((item, index) => <li><span>{String(index + 1).padStart(2, '0')}</span><strong>{item}</strong></li>)}</ul>
        </section>
      )}

      <section class="steps-section" aria-labelledby="steps-title">
        <div class="section-title dark"><p>GAME RULE</p><h2 id="steps-title">게임 방법</h2></div>
        <ol class="step-grid">{game.howToPlay.map((step, index) => <li><span>STEP {index + 1}</span><p>{step}</p></li>)}</ol>
      </section>

      {(game.winCondition || game.prizeRule) && (
        <section class="result-grid" aria-label="승리와 시상 안내">
          {game.winCondition && <article class="result-card win"><span aria-hidden="true">★</span><div><p>WIN CONDITION</p><h2>승리 조건</h2><strong>{game.winCondition}</strong></div></article>}
          {game.prizeRule && <article class="result-card prize"><span aria-hidden="true">▲</span><div><p>PRIZE RULE</p><h2>시상 기준</h2><strong>{game.prizeRule}</strong></div></article>}
        </section>
      )}

      <section class="event-info" aria-labelledby="info-title">
        <div class="section-title dark"><p>JOIN US</p><h2 id="info-title">참여 안내</h2></div>
        <dl>
          <div><dt>참가 비용</dt><dd>{game.price}</dd></div><div><dt>위치</dt><dd>{game.location}</dd></div><div><dt>운영 시간</dt><dd>{game.time}</dd></div><div class="notice"><dt>주의사항</dt><dd>{game.notice}</dd></div>
        </dl>
      </section>
    </div>

    <footer class="detail-footer shell"><a href={`${base}/play`}>← 놀거리 목록으로 돌아가기</a><span>KOINONIA MARKET PLAY ZONE</span></footer>
  </main>
</Layout>

<style>
  :global(body){background:#fff8e9}.detail-page{--accent:#2f9ff4;--accent-soft:#8ed9ff;min-height:100svh;overflow:hidden;color:#10234a;background:linear-gradient(180deg,#071e45 0 610px,#fff8e9 610px)}.accent-navy{--accent:#8ed9ff}.accent-orange{--accent:#ff6a20;--accent-soft:#ffaf7d}.accent-yellow{--accent:#ffd33d;--accent-soft:#fff0a1}.shell{width:min(1120px,calc(100% - 36px));margin-inline:auto}.detail-nav{position:relative;z-index:2;display:flex;justify-content:space-between;align-items:center;padding:24px 0;border-bottom:1px solid rgb(255 255 255/18%);color:white;font-size:12px;font-weight:900;letter-spacing:.04em}.detail-nav a,.detail-footer a{color:inherit;text-decoration:none}.detail-nav span{color:var(--accent)}.detail-hero{position:relative;display:grid;grid-template-columns:1fr auto;gap:30px;align-items:center;min-height:500px;padding-block:70px 100px;color:white}.detail-hero::before{position:absolute;right:-30vw;bottom:80px;width:65vw;height:14px;content:'';background:var(--accent);transform:rotate(-8deg)}.speed-lines{position:absolute;top:15%;left:-8%;width:170px;height:110px;opacity:.25;background:repeating-linear-gradient(-15deg,transparent 0 10px,var(--accent) 11px 13px,transparent 14px 24px)}.hero-content{position:relative;z-index:1}.game-label{margin:0 0 18px;color:var(--accent);font-size:12px;font-weight:900;letter-spacing:.15em}.detail-hero h1{margin:0;font-size:clamp(58px,10vw,120px);font-weight:900;line-height:.92;letter-spacing:-.08em;text-shadow:6px 7px 0 rgb(47 159 244/18%)}.tagline{max-width:720px;margin:25px 0 30px;color:rgb(255 255 255/78%);font-size:clamp(17px,2vw,23px);font-weight:700;line-height:1.55}.badge-row{display:flex;flex-wrap:wrap;gap:9px}.badge-row span{padding:9px 13px;border:1px solid rgb(255 255 255/22%);border-radius:999px;background:rgb(255 255 255/8%);font-size:12px;font-weight:800}.badge-row span:nth-child(2n){color:#071e45;background:var(--accent);border-color:var(--accent)}.versus-mark{position:relative;z-index:1;display:grid;width:150px;height:150px;place-items:center;border:3px solid var(--accent);border-radius:38% 62% 55% 45%;box-shadow:10px 10px 0 #ff6a20;transform:rotate(8deg)}.versus-mark span{color:var(--accent);font-size:42px;font-weight:900;transform:rotate(-8deg)}.media-section{position:relative;z-index:2;margin-top:-42px;padding:clamp(28px,5vw,60px);border-radius:28px;background:#0a2f69;box-shadow:0 25px 60px rgb(7 30 69/25%)}.section-title p{margin:0 0 8px;color:var(--accent);font-size:10px;font-weight:900;letter-spacing:.16em}.section-title h2{margin:0;color:white;font-size:clamp(28px,4vw,48px);letter-spacing:-.06em}.section-title>span{display:block;margin:10px 0 28px;color:rgb(255 255 255/66%);font-size:14px}.video-frame{overflow:hidden;border:1px solid rgb(255 255 255/20%);border-radius:22px;background:#03122e;box-shadow:0 18px 45px rgb(0 0 0/28%)}.video-frame video{display:block;width:100%;aspect-ratio:16/9;object-fit:contain;background:#020817}.team-tabs{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;color:#071e45;background:white;text-align:center;font-size:12px;font-weight:900}.team-tabs span{padding:15px;background:#8ed9ff}.team-tabs span:last-child{background:#ffd33d}.team-tabs b{padding:0 18px;color:white;background:#ff6a20;align-self:stretch;display:grid;place-items:center}.content-shell{display:grid;gap:80px;padding-block:100px}.info-card{padding:clamp(30px,5vw,60px);border-radius:26px;background:white;box-shadow:0 16px 40px rgb(16 35 74/8%);border-left:8px solid var(--accent)}.card-kicker{color:#ff6a20;font-size:10px;font-weight:900;letter-spacing:.15em}.info-card h2,.section-title.dark h2{margin:8px 0 18px;color:#10234a;font-size:clamp(30px,4vw,48px);letter-spacing:-.06em}.info-card p{max-width:850px;margin:0;color:#59677f;font-size:17px;line-height:1.8}.section-title.dark p{color:#ff6a20}.item-grid,.step-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin:28px 0 0;padding:0;list-style:none}.item-grid li{display:flex;gap:18px;align-items:center;padding:22px;border:1px solid #e1e6ef;border-radius:18px;background:white}.item-grid span{display:grid;width:42px;height:42px;place-items:center;border-radius:13px;color:#071e45;background:var(--accent);font-size:11px;font-weight:900}.step-grid li{min-height:150px;padding:24px;border-radius:20px;color:white;background:#071e45;box-shadow:0 12px 28px rgb(7 30 69/12%)}.step-grid li:nth-child(even){color:#071e45;background:var(--accent)}.step-grid span{font-size:10px;font-weight:900;letter-spacing:.12em;color:var(--accent)}.step-grid li:nth-child(even) span{color:#071e45}.step-grid p{margin:26px 0 0;font-size:15px;font-weight:700;line-height:1.65}.result-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}.result-card{display:grid;grid-template-columns:auto 1fr;gap:22px;align-items:center;padding:30px;border-radius:24px}.result-card>span{display:grid;width:64px;height:64px;place-items:center;border-radius:50%;font-size:25px}.result-card p{margin:0;color:#ff6a20;font-size:9px;font-weight:900;letter-spacing:.14em}.result-card h2{margin:5px 0 10px;font-size:26px}.result-card strong{font-size:14px;line-height:1.6}.result-card.win{background:#8ed9ff}.result-card.prize{background:#ffd33d}.result-card>span{color:white;background:#071e45}.event-info dl{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:28px 0 0}.event-info dl div{padding:22px;border-radius:18px;background:white;box-shadow:0 10px 24px rgb(16 35 74/6%)}.event-info dt{margin-bottom:8px;color:#ff6a20;font-size:10px;font-weight:900}.event-info dd{margin:0;font-size:14px;font-weight:800;line-height:1.55}.event-info .notice{grid-column:1/-1;color:white;background:#071e45}.event-info .notice dt{color:var(--accent)}.detail-footer{display:flex;justify-content:space-between;padding-block:34px;border-top:1px solid #d9dee8;font-size:12px;font-weight:900}.detail-footer span{color:#7b8598}@media(max-width:760px){.detail-page{background:linear-gradient(180deg,#071e45 0 690px,#fff8e9 690px)}.detail-nav{align-items:flex-start;flex-direction:column;gap:10px}.detail-hero{grid-template-columns:1fr;min-height:580px;padding-block:55px 95px}.versus-mark{width:95px;height:95px}.versus-mark span{font-size:28px}.media-section{width:calc(100% - 24px);padding:22px 14px}.content-shell{gap:60px;padding-block:75px}.item-grid,.step-grid,.result-grid,.event-info dl{grid-template-columns:1fr}.step-grid li{min-height:130px}.detail-footer{align-items:flex-start;flex-direction:column;gap:16px}}@media(max-width:480px){.shell{width:calc(100% - 24px)}.detail-hero h1{font-size:clamp(52px,17vw,76px)}.badge-row span{font-size:11px}.team-tabs b{padding-inline:12px}.info-card{padding:28px 22px}.result-card{grid-template-columns:1fr}.detail-footer span{font-size:10px}}
</style>
