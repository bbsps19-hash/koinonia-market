---
import Layout from '../../layouts/Layout.astro';
const { game } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const mediaSrc = game.mediaSrc ? `${base}${game.mediaSrc}` : null;
const isCupBattle = game.id === 'cup-battle';
const badges = isCupBattle ? ['팀 대항', '하늘팀 VS 노랑팀', game.price, '상위 3팀 시상'] : [game.price, game.location, game.time];
---

<Layout title={`${game.title} | 코이노니아 마켓 놀거리`} description={game.description}>
  <main class:list={['detail-page', `accent-${game.accent}`, { 'cup-page': isCupBattle }]}>
    <header class="detail-nav shell">
      <a href={`${base}/play`}>← 놀거리 목록으로 돌아가기</a>
      <span>4청 선교마켓 · GAME {game.number}</span>
    </header>

    <section class="detail-hero shell">
      <div class="speed-lines" aria-hidden="true"></div>
      <div class="hero-content">
        <p class="game-label">PLAY ZONE · {game.number}</p>
        <h1>{game.title}</h1>
        <p class="tagline">{game.shortDescription}</p>
        <div class="badge-row">{badges.map((badge) => <span>{badge}</span>)}</div>
      </div>
      <div class="versus-mark" aria-hidden="true"><span>{game.icon}</span></div>
    </section>

    {game.mediaType === 'video' && mediaSrc && (
      <section class="media-section shell" aria-labelledby="media-title">
        <div class="section-title"><p>HOW TO PLAY</p><h2 id="media-title">영상으로 먼저 만나보세요</h2><span>예시 영상을 보고 게임 방식을 빠르게 확인해보세요.</span></div>
        <div class="video-frame">
          <video src={mediaSrc} controls playsinline preload="metadata" aria-label={`${game.title} 게임 방법 예시 영상`}></video>
          <div class="team-tabs" aria-hidden="true"><span>SKY TEAM</span><b>VS</b><span>YELLOW TEAM</span></div>
        </div>
      </section>
    )}

    <div class="content-shell shell">
      <section class="intro-card info-card" aria-labelledby="intro-title">
        <span class="card-kicker">ABOUT GAME</span><h2 id="intro-title">게임 소개</h2><p>{game.description}</p>
      </section>

      {game.peopleAndItems && (
        <section class="items-section" aria-labelledby="items-title">
          <div class="section-title dark"><p>READY</p><h2 id="items-title">인원 및 준비물</h2></div>
          <ul class="item-grid">{game.peopleAndItems.map((item, index) => <li><span>{String(index + 1).padStart(2, '0')}</span><strong>{item}</strong></li>)}</ul>
        </section>
      )}

      <section class="steps-section" aria-labelledby="steps-title">
        <div class="section-title dark"><p>GAME RULE</p><h2 id="steps-title">게임 방법</h2></div>
        <ol class="step-grid">{game.howToPlay.map((step, index) => <li><span>STEP {index + 1}</span><p>{step}</p></li>)}</ol>
      </section>

      {(game.winCondition || game.prizeRule) && (
        <section class="result-grid" aria-label="승리와 시상 안내">
          {game.winCondition && <article class="result-card win"><span aria-hidden="true">★</span><div><p>WIN CONDITION</p><h2>승리 조건</h2><strong>{game.winCondition}</strong></div></article>}
          {game.prizeRule && <article class="result-card prize"><span aria-hidden="true">▲</span><div><p>PRIZE RULE</p><h2>시상 기준</h2><strong>{game.prizeRule}</strong></div></article>}
        </section>
      )}

      <section class="event-info" aria-labelledby="info-title">
        <div class="section-title dark"><p>JOIN US</p><h2 id="info-title">참여 안내</h2></div>
        <dl>
          <div><dt>참가 비용</dt><dd>{game.price}</dd></div><div><dt>위치</dt><dd>{game.location}</dd></div><div><dt>운영 시간</dt><dd>{game.time}</dd></div><div class="notice"><dt>주의사항</dt><dd>{game.notice}</dd></div>
        </dl>
      </section>
    </div>

    <footer class="detail-footer shell"><a href={`${base}/play`}>← 놀거리 목록으로 돌아가기</a><span>KOINONIA MARKET PLAY ZONE</span></footer>
  </main>
</Layout>


<style>
  :global(body) { background: #f7f1e7; }
  .detail-page {
    --navy: #0b2347;
    --navy-soft: #17365f;
    --cream: #f7f1e7;
    --paper: #fffdf8;
    --orange: #ed6b2d;
    --text: #17243a;
    --muted: #657086;
    --line: #e2ddd3;
    min-height: 100svh;
    color: var(--text);
    background: linear-gradient(180deg, var(--navy) 0 560px, var(--cream) 560px);
  }
  .shell { width: min(1060px, calc(100% - 40px)); margin-inline: auto; }
  .detail-nav { display: flex; justify-content: space-between; align-items: center; padding: 22px 0; border-bottom: 1px solid rgb(255 255 255 / 16%); color: white; font-size: 12px; font-weight: 800; }
  .detail-nav a, .detail-footer a { color: inherit; text-decoration: none; }
  .detail-nav a:hover, .detail-footer a:hover { color: var(--orange); }
  .detail-nav span { color: rgb(255 255 255 / 62%); }
  .detail-hero { display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center; min-height: 470px; padding: 70px 0 95px; color: white; }
  .speed-lines { display: none; }
  .game-label, .card-kicker, .section-title p { margin: 0 0 10px; color: var(--orange); font-size: 10px; font-weight: 900; letter-spacing: .15em; }
  .detail-hero h1 { margin: 0; font-size: clamp(54px, 9vw, 104px); font-weight: 900; line-height: .98; letter-spacing: -.075em; }
  .tagline { max-width: 720px; margin: 22px 0 28px; color: rgb(255 255 255 / 76%); font-size: clamp(17px, 2vw, 22px); line-height: 1.6; }
  .badge-row { display: flex; flex-wrap: wrap; gap: 8px; }
  .badge-row span { padding: 8px 12px; border: 1px solid rgb(255 255 255 / 22%); border-radius: 999px; color: rgb(255 255 255 / 88%); background: rgb(255 255 255 / 6%); font-size: 12px; font-weight: 700; }
  .badge-row span:first-child { border-color: var(--orange); color: white; background: var(--orange); }
  .versus-mark { display: grid; width: 112px; height: 112px; place-items: center; border: 2px solid rgb(255 255 255 / 28%); border-radius: 24px; background: rgb(255 255 255 / 6%); }
  .versus-mark span { color: var(--orange); font-size: 30px; font-weight: 900; }
  .media-section { margin-top: -38px; padding: clamp(26px, 4vw, 44px); border: 1px solid var(--line); border-radius: 22px; background: var(--paper); box-shadow: 0 18px 45px rgb(11 35 71 / 12%); }
  .media-section .section-title h2 { color: var(--text); }
  .section-title h2, .info-card h2 { margin: 0; color: var(--text); font-size: clamp(28px, 4vw, 42px); line-height: 1.18; letter-spacing: -.055em; }
  .section-title > span { display: block; margin: 9px 0 25px; color: var(--muted); font-size: 14px; }
  .video-frame { overflow: hidden; border: 1px solid #d9dfe7; border-radius: 16px; background: #08162e; }
  .video-frame video { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: contain; background: #050d1c; }
  .team-tabs { display: grid; grid-template-columns: 1fr auto 1fr; color: var(--navy); background: white; font-size: 11px; font-weight: 900; text-align: center; }
  .team-tabs span { padding: 12px; border-top: 4px solid #8ed9ff; }
  .team-tabs span:last-child { border-color: #ffd33d; }
  .team-tabs b { display: grid; place-items: center; padding: 0 16px; color: white; background: var(--navy); }
  .content-shell { display: grid; gap: 36px; padding: 72px 0 90px; }
  .info-card, .items-section, .steps-section, .result-grid, .event-info { border: 1px solid var(--line); border-radius: 20px; background: var(--paper); box-shadow: 0 10px 28px rgb(11 35 71 / 6%); }
  .info-card, .items-section, .steps-section, .event-info { padding: clamp(28px, 4vw, 44px); }
  .info-card { border-top: 4px solid var(--orange); }
  .info-card p { max-width: 850px; margin: 18px 0 0; color: var(--muted); font-size: 16px; line-height: 1.85; }
  .item-grid, .step-grid { display: grid; gap: 10px; margin: 24px 0 0; padding: 0; list-style: none; }
  .item-grid { grid-template-columns: repeat(2, 1fr); }
  .item-grid li { display: flex; gap: 14px; align-items: center; padding: 17px 18px; border: 1px solid var(--line); border-radius: 12px; background: white; }
  .item-grid span { display: grid; width: 34px; height: 34px; flex: 0 0 auto; place-items: center; border-radius: 9px; color: white; background: var(--navy); font-size: 10px; font-weight: 900; }
  .item-grid strong { font-size: 14px; }
  .step-grid { grid-template-columns: repeat(2, 1fr); counter-reset: step; }
  .step-grid li { min-height: 118px; padding: 20px; border: 1px solid var(--line); border-radius: 12px; background: white; }
  .step-grid span { color: var(--orange); font-size: 10px; font-weight: 900; letter-spacing: .1em; }
  .step-grid p { margin: 20px 0 0; color: var(--text); font-size: 14px; font-weight: 700; line-height: 1.65; }
  .result-grid { display: grid; grid-template-columns: repeat(2, 1fr); overflow: hidden; }
  .result-card { display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: start; padding: 30px; }
  .result-card + .result-card { border-left: 1px solid var(--line); }
  .result-card > span { display: grid; width: 42px; height: 42px; place-items: center; border-radius: 10px; color: white; background: var(--navy); font-size: 16px; }
  .result-card p { margin: 0; color: var(--orange); font-size: 9px; font-weight: 900; letter-spacing: .12em; }
  .result-card h2 { margin: 5px 0 9px; font-size: 22px; }
  .result-card strong { color: var(--muted); font-size: 14px; line-height: 1.65; }
  .event-info dl { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin: 24px 0 0; border: 1px solid var(--line); border-radius: 14px; overflow: hidden; }
  .event-info dl div { padding: 20px; background: white; }
  .event-info dl div + div { border-left: 1px solid var(--line); }
  .event-info dt { margin-bottom: 7px; color: var(--orange); font-size: 10px; font-weight: 900; }
  .event-info dd { margin: 0; font-size: 14px; font-weight: 750; line-height: 1.55; }
  .event-info .notice { grid-column: 1 / -1; border-top: 1px solid var(--line); border-left: 0; background: #f3eee5; }
  .event-info .notice dd { color: #4e596c; font-weight: 650; }
  .detail-footer { display: flex; justify-content: space-between; padding: 30px 0; border-top: 1px solid #d9d2c7; color: var(--navy); font-size: 12px; font-weight: 900; }
  .detail-footer span { color: #7b8391; }
  @media (max-width: 760px) {
    .detail-page { background: linear-gradient(180deg, var(--navy) 0 620px, var(--cream) 620px); }
    .detail-nav { align-items: flex-start; flex-direction: column; gap: 9px; }
    .detail-hero { grid-template-columns: 1fr; gap: 32px; min-height: 530px; padding: 55px 0 85px; }
    .versus-mark { width: 78px; height: 78px; border-radius: 18px; }
    .versus-mark span { font-size: 22px; }
    .media-section { width: calc(100% - 24px); padding: 22px 14px; }
    .content-shell { gap: 22px; padding: 58px 0 72px; }
    .item-grid, .step-grid, .result-grid, .event-info dl { grid-template-columns: 1fr; }
    .result-card + .result-card { border-top: 1px solid var(--line); border-left: 0; }
    .event-info dl div + div { border-top: 1px solid var(--line); border-left: 0; }
    .detail-footer { align-items: flex-start; flex-direction: column; gap: 14px; }
  }
  @media (max-width: 480px) {
    .shell { width: calc(100% - 24px); }
    .detail-hero h1 { font-size: clamp(50px, 16vw, 70px); }
    .badge-row span { font-size: 11px; }
    .info-card, .items-section, .steps-section, .event-info { padding: 24px 20px; }
    .result-card { grid-template-columns: 1fr; padding: 24px 20px; }
    .team-tabs b { padding-inline: 10px; }
  }
</style>
