---
import TargetMasterPage from '../../../components/play/TargetMasterPage.astro';

const targetMaster = {
  id: 'target-master',
  title: '타겟마스터',
  subtitle: '과녁을 쓰러뜨리고 캡슐을 뽑아라!',
  posterImage: '/ready/타겟 마스터 포스터.png',
  summary: '너프건으로 과녁을 맞히고, 점수에 따라 캡슐 속 선물을 뽑아가는 아케이드형 타겟 게임입니다.',
  badges: ['1~2인 참여', '총 70초', '캡슐 보상', '테마 선택 가능'],
  gameDescription: [
    '1~2인이 참여할 수 있습니다.',
    '너프건으로 과녁을 쓰러뜨리는 간단한 게임입니다.',
    '총 70초 동안 진행됩니다.',
    '시간 안에 맞힌 점수대로 캡슐을 뽑을 수 있습니다.',
    '과녁을 많이 넘길수록 더 많은 캡슐을 얻을 수 있습니다.',
  ],
  steps: [
    '참가 후 원하는 테마를 선택합니다.',
    '선택한 테마 화면과 사운드를 확인합니다.',
    '제한 시간 70초 동안 너프건으로 과녁을 맞힙니다.',
    '과녁을 쓰러뜨리면 점수가 올라갑니다.',
    '시간 종료 후 점수에 따라 캡슐을 뽑습니다.',
    '캡슐 속 선물을 받아갑니다.',
  ],
  themes: [
    { name: '아케이드', description: '네온 게임장 분위기의 기본 테마', image: '/ready/아케이드 맵고르기.png', alt: '타겟마스터 아케이드 테마 선택 화면' },
    { name: '메탈슬러그', description: '전투 게임 느낌의 박진감 있는 테마', image: '/ready/메탈슬러그 맵고르기.png', alt: '타겟마스터 메탈슬러그 테마 선택 화면' },
    { name: '스타워즈', description: '우주 전투 느낌의 웅장한 테마', image: '/ready/스타워즈 맵고르기.png', alt: '타겟마스터 스타워즈 테마 선택 화면' },
    { name: '랜덤', description: '어떤 테마가 나올지 모르는 랜덤 선택', image: null },
  ],
  modes: [
    { name: '손잡고 함께가세', type: '협동형 과녁 게임', highlight: '함께 과녁을 넘기는 협동버전', subText: '일정 점수 이상 시 원하는 선물 선택!', description: '두 사람이 같은 과녁을 함께 공략하는 협동 모드입니다. 힘을 합쳐 일정 점수 이상 달성하면 원하는 선물을 선택할 수 있습니다.', accent: 'blue', image: '/ready/손잡고 함께가세.png', alt: '손잡고 함께가세 협동형 과녁 게임 안내' },
    { name: '선한싸움 다싸우고', type: '대결형 과녁 게임', highlight: '서로 다른 과녁으로 대결', subText: '제한 시간 안에 쓰러뜨린 과녁 수로 승부', description: '두 사람이 각자의 과녁을 공략하는 대결 모드입니다. 제한 시간 안에 더 많은 과녁을 쓰러뜨린 사람이 승리합니다.', accent: 'orange', image: '/ready/선한싸움 다싸우고.png', alt: '선한싸움 다싸우고 대결형 과녁 게임 안내' },
  ],
  rewards: ['점수가 높을수록 더 많은 캡슐 획득', '과녁을 많이 넘길수록 보상 기회 증가', '협동 모드에서 일정 점수 이상 달성 시 원하는 선물 선택 기회'],
  prizes: [
    { name: '왁뿌볼', description: '초록색 말랑한 공 느낌의 캡슐 선물', visual: 'ball' },
    { name: '말랑이', description: '귀여운 말랑이 장난감', visual: 'squishy' },
    { name: '키링', description: '가방이나 열쇠에 달 수 있는 작은 키링', visual: 'keyring' },
    { name: '등 다양한 선물', description: '무엇이 나올지 모르는 다양한 캡슐 선물', visual: 'mystery' },
  ],
  notices: ['사람을 향해 너프건을 쏘면 안 됩니다.', '과녁을 향해서만 너프건을 쏴야 합니다.', '시간이 초과되면 점수가 나도 인정되지 않습니다.', '너프건으로 인해 생긴 인명피해 및 금전적 손실은 책임지지 않습니다.'],
};
---
<TargetMasterPage game={targetMaster} />
