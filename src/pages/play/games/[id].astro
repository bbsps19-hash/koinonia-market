---
import GameDetailPage from '../../../components/play/GameDetailPage.astro';
import { playGames } from '../../../data/play.js';

export function getStaticPaths() {
  return playGames.filter((game) => game.id !== 'target-master').map((game) => ({ params: { id: game.id }, props: { game } }));
}

const { game } = Astro.props;
---
<GameDetailPage {game} />
