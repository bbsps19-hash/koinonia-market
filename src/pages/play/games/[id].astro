---
import GameDetailPage from '../../../components/play/GameDetailPage.astro';
import BoardGamePage from '../../../components/play/BoardGamePage.astro';
import LuckyDrawPage from '../../../components/play/LuckyDrawPage.astro';
import CupBattlePage from '../../../components/play/CupBattlePage.astro';
import { playGames } from '../../../data/play.js';

export function getStaticPaths() {
  return playGames.filter((game) => ['board-game', 'lucky-draw', 'cup-battle'].includes(game.id)).map((game) => ({ params: { id: game.id }, props: { game } }));
}

const { game } = Astro.props;
---
{game.id === 'board-game' ? <BoardGamePage /> : game.id === 'lucky-draw' ? <LuckyDrawPage /> : game.id === 'cup-battle' ? <CupBattlePage /> : <GameDetailPage {game} />}
