---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="코이노니아 마켓">
	<div class="intro" data-intro>
		<video class="intro__video" data-intro-video src={`${base}/assets/koinonia-market.mp4`} autoplay muted playsinline preload="auto" aria-label="코이노니아 마켓 오프닝 영상"></video>
		<button class="intro__skip" type="button" data-skip>건너뛰기</button>
	</div>

	<main class="market" data-market aria-label="코이노니아 마켓 메인" style={`--poster-url: url(${base}/assets/koinonia-market-base.png)`}>
		<div class="market__backdrop" aria-hidden="true"></div>
		<section class="market__poster">
			<img src={`${base}/assets/koinonia-market-base.png`} alt="코이노니아 마켓" width="1448" height="1086" fetchpriority="high" />
			<img class="waving-hand" src={`${base}/assets/koinonia-hand.png`} alt="" width="188" height="145" aria-hidden="true" />
			<nav class="market__nav" aria-label="마켓 둘러보기">
				<a class="market-link hotspot food" href={`${base}/food/`} aria-label="먹거리 페이지로 이동"><span>먹거리 보러가기</span></a>
				<a class="market-link hotspot goods" href={`${base}/goods/`} aria-label="팔거리 페이지로 이동"><span>팔거리 보러가기</span></a>
				<a class="market-link hotspot play" href={`${base}/play/`} aria-label="놀거리 페이지로 이동"><span>놀거리 보러가기</span></a>
			</nav>
		</section>
	</main>

	<script>
		const intro = document.querySelector('[data-intro]');
		const video = document.querySelector('[data-intro-video]');
		const skip = document.querySelector('[data-skip]');
		const market = document.querySelector('[data-market]');
		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		let entered = false;
		const enter = () => {
			if (entered) return;
			entered = true;
			market?.classList.add('is-visible');
			intro?.classList.add('is-finished');
			window.setTimeout(() => intro?.remove(), reduceMotion ? 0 : 700);
		};
		if (reduceMotion) {
			video?.pause();
			enter();
		} else {
			video?.addEventListener('ended', enter, { once: true });
			video?.addEventListener('error', enter, { once: true });
			skip?.addEventListener('click', enter, { once: true });
			video?.play()?.catch(() => window.setTimeout(enter, 800));
			window.setTimeout(enter, 12000);
		}
	</script>
</Layout>

<style>
	.intro { position: fixed; inset: 0; z-index: 10; display: grid; place-items: center; overflow: hidden; background: #f1e6cc; transition: opacity 600ms ease, visibility 600ms ease; }
	.intro::after { position: absolute; inset: 0; content: ''; pointer-events: none; box-shadow: inset 0 0 100px rgb(44 34 17 / 18%); }
	.intro.is-finished { visibility: hidden; opacity: 0; }
	.intro__video { width: 100%; height: 100%; object-fit: cover; }
	.intro__skip { position: absolute; right: clamp(18px, 3vw, 42px); bottom: clamp(18px, 3vw, 36px); z-index: 1; padding: 10px 17px; border: 1px solid rgb(255 255 255 / 55%); border-radius: 999px; color: white; background: rgb(24 20 13 / 45%); font-size: 13px; font-weight: 700; cursor: pointer; backdrop-filter: blur(10px); transition: 180ms ease; }
	.intro__skip:hover { background: rgb(24 20 13 / 68%); transform: translateY(-2px); }
	.market { position: relative; display: grid; min-height: 100svh; place-items: center; overflow: hidden; padding: clamp(14px, 2.5vw, 38px); opacity: 0; background: #d8c5a2; }
	.market__backdrop { position: absolute; inset: -40px; background: linear-gradient(rgb(75 53 24 / 22%), rgb(75 53 24 / 22%)), var(--poster-url) center / cover; filter: blur(32px) saturate(.7); transform: scale(1.1); }
	.market__poster { position: relative; width: min(100%, calc((100svh - clamp(28px, 5vw, 76px)) * 1.3333)); overflow: hidden; border: 1px solid rgb(255 255 255 / 32%); border-radius: clamp(8px, 1.4vw, 20px); box-shadow: 0 32px 80px rgb(37 25 9 / 33%), 0 3px 10px rgb(37 25 9 / 16%); transform: translateY(110vh) scale(.96); }
	.market.is-visible { opacity: 1; }
	.market.is-visible .market__poster { animation: poster-rise 1000ms cubic-bezier(.16, 1, .3, 1) 100ms both; }
	.market__poster > img:first-child { display: block; width: 100%; height: auto; }
	.waving-hand { position: absolute; top: 0; left: 87.016%; z-index: 2; width: 12.983%; height: 13.352%; object-fit: contain; transform-origin: 58% 96%; will-change: transform; pointer-events: none; }
	.market.is-visible .waving-hand { animation: none; }
	.market__nav { position: absolute; inset: 0; }
	.market-link { position: absolute; z-index: 1; border-radius: 24px; color: white; cursor: pointer; text-decoration: none; transition: background 200ms ease, box-shadow 200ms ease, transform 200ms ease; }
	.market-link.food { --sparkle-main: #ff3f32; --sparkle-soft: #ff9a58; left: 7%; top: 34%; width: 27%; height: 18%; }
	.market-link.goods { --sparkle-main: #ffe135; --sparkle-soft: #7dff63; left: 36%; top: 34%; width: 27%; height: 18%; }
	.market-link.play { --sparkle-main: #28b9ff; --sparkle-soft: #79e9ff; left: 65%; top: 34%; width: 28%; height: 18%; }
	.market-link::before, .market-link::after { position: absolute; z-index: 3; line-height: 1; pointer-events: none; transform-origin: center; }
	.market-link::after { content: '✦'; font-size: clamp(17px, 2vw, 32px); color: var(--sparkle-main); text-shadow: 0 0 4px white, 0 0 12px var(--sparkle-main), 0 0 26px var(--sparkle-main), 0 0 38px var(--sparkle-main); animation: sparkle-blink 1.6s ease-in-out infinite; }
	.market-link::before { content: '✧'; font-size: clamp(9px, 1.05vw, 17px); color: var(--sparkle-soft); text-shadow: 0 0 4px white, 0 0 11px var(--sparkle-soft), 0 0 22px var(--sparkle-soft); animation: sparkle-drift 1.6s ease-in-out .18s infinite; }
	.market-link.food::after { left: 2%; top: -8%; }
	.market-link.food::before { left: 13%; top: 5%; }
	.market-link.goods::after { left: 5%; top: -10%; animation-delay: .25s; }
	.market-link.goods::before { left: 16%; top: 3%; animation-delay: .43s; }
	.market-link.play::after { right: 2%; top: -10%; animation-delay: .5s; }
	.market-link.play::before { right: 14%; top: 4%; animation-delay: .68s; }
	.market-link:hover::after, .market-link:focus-visible::after { animation-duration: .8s; filter: brightness(1.15); }
	.market-link:hover::before, .market-link:focus-visible::before { animation-duration: .8s; filter: brightness(1.15); }
	.market-link span { position: absolute; left: 50%; bottom: -13px; padding: 7px 11px; border: 1px solid rgb(255 255 255 / 62%); border-radius: 999px; opacity: 0; color: white; background: rgb(38 29 19 / 78%); box-shadow: 0 6px 18px rgb(31 22 12 / 24%); font-size: clamp(8px, .9vw, 12px); font-weight: 800; white-space: nowrap; pointer-events: none; transform: translate(-50%, 7px); transition: opacity 200ms ease, transform 200ms ease; backdrop-filter: blur(8px); }
	.market-link:hover { z-index: 3; background: rgb(255 255 255 / 13%); box-shadow: 0 0 0 2px rgb(255 255 255 / 48%), 0 12px 30px rgb(255 255 255 / 18%), inset 0 0 28px rgb(255 255 255 / 12%); transform: scale(1.03); }
	.market-link:hover span, .market-link:focus-visible span { opacity: 1; transform: translate(-50%, 0); }
	.market-link:focus-visible { z-index: 4; outline: 3px solid white; outline-offset: 3px; background: rgb(255 255 255 / 14%); box-shadow: 0 0 24px rgb(255 255 255 / 28%); transform: scale(1.03); }
	.market-link:active { background: rgb(255 255 255 / 22%); box-shadow: inset 0 0 24px rgb(255 255 255 / 18%); transform: scale(1.01); }
	@keyframes hand-wave {
		0%, 8%, 62%, 100% { transform: translate(0, 0) rotate(0deg); }
		16% { transform: translate(-7%, -2%) rotate(-20deg); }
		25% { transform: translate(6%, 1%) rotate(17deg); }
		34% { transform: translate(-6%, -2%) rotate(-18deg); }
		43% { transform: translate(5%, 1%) rotate(14deg); }
		52% { transform: translate(-3%, -1%) rotate(-9deg); }
	}
	@keyframes poster-rise { 0% { opacity: 0; transform: translateY(110vh) scale(.96); } 70% { opacity: 1; transform: translateY(-2.2%) scale(1); } 100% { opacity: 1; transform: none; } }
	@keyframes sparkle-blink { 0%, 100% { opacity: .55; transform: scale(.82) rotate(0deg) translateY(0); } 50% { opacity: 1; transform: scale(1.25) rotate(12deg) translateY(-3px); } }
	@keyframes sparkle-drift { 0%, 100% { opacity: .5; transform: scale(.86) rotate(-5deg) translateY(1px); } 50% { opacity: .9; transform: scale(1.12) rotate(6deg) translateY(-2px); } }
	@media (max-width: 640px) {
		.market { padding: 10px; }
		.market__poster { width: 100%; }
	}
	@media (prefers-reduced-motion: reduce) {
		.intro { display: none; }
		.market, .market__poster { opacity: 1; transform: none; }
		.market.is-visible .market__poster, .market.is-visible .waving-hand { animation: none; }
		.market-link::before, .market-link::after { animation: none; opacity: .8; }
	}
</style>
