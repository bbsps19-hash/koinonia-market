---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="코이노니아 마켓">
	<main class="market" aria-label="코이노니아 마켓 메인" style={`--poster-url: url("${base}/assets/메인.png")`}>
		<div class="market__backdrop" aria-hidden="true"></div>
		<section class="market__poster">
			<img src={`${base}/assets/메인.png`} alt="코이노니아 마켓" width="1055" height="1491" fetchpriority="high" />
			<a class="play-cta" href={`${base}/play/`}>
				<span>놀거리 더 알아보기</span>
				<span aria-hidden="true">→</span>
			</a>
		</section>
	</main>
</Layout>

<style>
	.market { position: relative; display: grid; min-height: 100svh; place-items: center; overflow: hidden; padding: clamp(14px, 2.5vw, 38px); background: #d8c5a2; }
	.market__backdrop { position: absolute; inset: -40px; background: linear-gradient(rgb(75 53 24 / 22%), rgb(75 53 24 / 22%)), var(--poster-url) center / cover; filter: blur(32px) saturate(.7); transform: scale(1.1); }
	.market__poster { position: relative; width: min(100%, calc((100svh - clamp(28px, 5vw, 76px)) * .7076)); overflow: hidden; border: 1px solid rgb(255 255 255 / 32%); border-radius: clamp(8px, 1.4vw, 20px); box-shadow: 0 32px 80px rgb(37 25 9 / 33%), 0 3px 10px rgb(37 25 9 / 16%); animation: poster-enter 700ms cubic-bezier(.16, 1, .3, 1) both; }
	.market__poster > img:first-child { display: block; width: 100%; height: auto; }
	.play-cta { position: absolute; right: 7%; bottom: 5%; left: 7%; display: flex; align-items: center; justify-content: center; gap: .65em; min-height: 52px; padding: 14px 22px; border: 2px solid rgb(255 255 255 / 80%); border-radius: 999px; color: white; background: rgb(58 45 145 / 92%); box-shadow: 0 10px 26px rgb(35 27 90 / 34%); font-size: clamp(16px, 2.2vw, 24px); font-weight: 800; text-decoration: none; backdrop-filter: blur(8px); transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease; -webkit-tap-highlight-color: transparent; }
	.play-cta:hover { background: #5147d9; box-shadow: 0 13px 30px rgb(35 27 90 / 42%); transform: translateY(-3px); }
	.play-cta:focus-visible { outline: 4px solid rgb(255 255 255 / 86%); outline-offset: 3px; }
	.play-cta:active { transform: translateY(0); }
	@keyframes poster-enter { from { opacity: 0; transform: translateY(32px) scale(.98); } to { opacity: 1; transform: none; } }
	@media (max-width: 640px) {
		.market { padding: 10px; }
		.market__poster { width: min(100%, calc((100svh - 20px) * .7076)); }
		.play-cta { min-height: 46px; padding: 11px 16px; }
	}
	@media (prefers-reduced-motion: reduce) {
		.market__poster { animation: none; }
		.play-cta { transition: none; }
	}
</style>
