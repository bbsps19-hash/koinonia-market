	{ number: '01', name: '함께하는 게임', note: '처음 만난 사람과도 금세 가까워지는 시간' },
	{ number: '02', name: '즐거운 공연', note: '보고 듣고 박수치며 하나가 되는 무대' },
	{ number: '03', name: '마음껏 체험', note: '직접 만들고 움직이며 발견하는 즐거움' },
